                            	  2593: 
                            	  2594: RECV_CHAR:
01:0009168A 243C00027100    	  2595: 	MOVE.L	#20*SERIAL_RETRYS,D2	;Number of times to try reading serial port before aborting.
01:00091690 61000256        	  2596: 	BSR	RECV	;GET CHAR
01:00091694 B43C00FF        	  2597: 	CMP.B	#$FF,D2	;GET CMA'D SECT #
01:00091698 6600FF34        	  2598: 	BNE	RECV_HDR_TIMEOUT
