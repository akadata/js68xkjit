                            	  1895: 	
                            	  1896: ;==================== Support Routines FOR IDE MODULE ==================================
                            	  1897: 
                            	  1898: ;Generate an LBA sector number with data input from CPM style Track# & Sector#
                            	  1899: 
                            	  1900: GEN_HEX32_LBA:
01:00090F7E 45FA1630        	  1901: 	LEA	ENTERRAM_SECL,A2	;Enter sector number, low
01:00090F82 610009BE        	  1902: 	BSR	PRINT_STRING
01:00090F86 610007FE        	  1903: 	BSR	GETBYTE_D7	;Get 8 bit value (2 digits) to D7
01:00090F8A 13C70009850D    	  1904: 	MOVE.B	D7,(RAM_SEC)
01:00090F90 610009BE        	  1905: 	BSR	CRLF
                            	  1906: 
01:00090F94 45FA167D        	  1907: 	LEA	ENTERRAM_TRKL,A2	;Enter low byte track number
01:00090F98 610009A8        	  1908: 	BSR	PRINT_STRING
01:00090F9C 610007E8        	  1909: 	BSR	GETBYTE_D7	;Get 8 bit value (2 digits) to D7
01:00090FA0 13C70009850E    	  1910: 	MOVE.B	D7,RAM_TRK
01:00090FA6 610009A8        	  1911: 	BSR	CRLF
                            	  1912: 
01:00090FAA 45FA1687        	  1913: 	LEA	ENTERRAM_TRKH,A2	;Enter high byte track number
01:00090FAE 61000992        	  1914: 	BSR	PRINT_STRING
01:00090FB2 610007D2        	  1915: 	BSR	GETBYTE_D7	;Get 8 bit value (2 digits) to D7
01:00090FB6 13C70009850F    	  1916: 	MOVE.B	D7,(RAM_TRK+1)
01:00090FBC 4201            	  1917: 	CLR.B	D1	;To return NC
01:00090FBE 4E75            	  1918: 	RTS
                            	  1919: 
                            	  1920: 
                            	  1921: DISPLAY_POSITION:		;Display current track,sector & head position
01:00090FC0 45FA14DE        	  1922: 	LEA	msgCPMTRK,A2	;Display in LBA format
01:00090FC4 6100097C        	  1923: 	BSR	PRINT_STRING	;---- CPM FORMAT ----
01:00090FC8 1C3A7545        	  1924: 	MOVE.B	(RAM_TRK+1),D6
01:00090FCC 61000858        	  1925: 	BSR	PUTBYTE_D6	;High TRK byte
01:00090FD0 1C3A753C        	  1926: 	MOVE.B	(RAM_TRK),D6
01:00090FD4 61000850        	  1927: 	BSR	PUTBYTE_D6	;Low TRK byte
                            	  1928: 
01:00090FD8 45FA14D1        	  1929: 	LEA	msgCPMSEC,A2
01:00090FDC 61000964        	  1930: 	BSR	PRINT_STRING	;SEC = (16 bits)
01:00090FE0 1C3A752C        	  1931: 	MOVE.B	(RAM_SEC+1),D6	;High Sec
01:00090FE4 61000840        	  1932: 	BSR	PUTBYTE_D6
01:00090FE8 1C3A7523        	  1933: 	MOVE.B	(RAM_SEC),D6	;Low Sec
01:00090FEC 61000838        	  1934: 	BSR	PUTBYTE_D6
                            	  1935: 	
                            	  1936: 			;---- LBA FORMAT ----
01:00090FF0 45FA14C5        	  1937: 	LEA	msgLBA,A2
01:00090FF4 6100094C        	  1938: 	BSR	PRINT_STRING	;(LBA = 00 (<-- Old "Heads" = 0 for these drives).
                            	  1939: 	
01:00090FF8 1C3A750F        	  1940: 	MOVE.B	(RAM_DRIVE_TRK+1),D6	;High "cylinder" byte
01:00090FFC 61000828        	  1941: 	BSR	PUTBYTE_D6
01:00091000 1C3A7506        	  1942: 	MOVE.B	(RAM_DRIVE_TRK),D6	;Low "cylinder" byte
