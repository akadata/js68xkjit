                            	  2417: 	
                            	  2418: 
                            	  2419: ;------------------------------------------------------------------
                            	  2420: ; Low Level 8 bit R/W to the drive controller.  These are the routines that talk
                            	  2421: ; directly to the drive controller registers, via the 8255 chip.  
                            	  2422: ; Note the 16 bit Sector I/O to the drive is done directly 
                            	  2423: ; in the routines READSECTOR & WRITESECTOR for speed reasons.
                            	  2424: 
                            	  2425: IDErd8D:				;READ 8 bits from IDE register @ [DL], return info in [DH]
01:000914A2 13C500FF0032    	  2426: 	MOVE.B	D5,IDEportC		;Select IDE register, drive address onto control lines
                            	  2427: 	
01:000914A8 0039004000FF0032	  2428: 	OR.B	#IDErdline,IDEportC		;RD pulse pin (40H), Assert read pin
                            	  2429: 
01:000914B0 183900FF0030    	  2430: 	MOVE.B	IDEportA,D4		;Return with data in [D4]
                            	  2431: 	
01:000914B6 13C500FF0032    	  2432: 	MOVE.B	D5,IDEportC		;Select IDE register, drive address onto control lines
                            	  2433: 
01:000914BC 13FC000000FF0032	  2434: 	MOVE.B	#0,IDEportC		;Zero all port C lines
01:000914C4 4E75            	  2435: 	RTS
                            	  2436: 
                            	  2437: 
                            	  2438: IDEwr8D:					;WRITE Data in [DH] to IDE register @ [DL]
01:000914C6 13FC008000FF0033	  2439: 	MOVE.B	#WRITEcfg8255,IDECtrlPort	;Set 8255 to write mode
                            	  2440: 	
01:000914CE 13C400FF0030    	  2441: 	MOVE.B	D4,IDEportA			;Get data put it in 8255 A port
                            	  2442: 	
01:000914D4 13C500FF0032    	  2443: 	MOVE.B	D5,IDEportC			;Select IDE register, drive address onto control lines
                            	  2444: 	
01:000914DA 0039002000FF0032	  2445: 	OR.B	#IDEwrline,IDEportC			;Assert write pin
                            	  2446: 	
01:000914E2 13C500FF0032    	  2447: 	MOVE.B	D5,IDEportC			;Select IDE register, drive address onto control lines
                            	  2448: 
01:000914E8 13FC000000FF0032	  2449: 	MOVE.B	#0,IDEportC			;Zero all port C lines
                            	  2450: 	
01:000914F0 13FC009200FF0033	  2451: 	MOVE.B	#READcfg8255,IDECtrlPort	;Config 8255 chip, read mode on return
01:000914F8 4E75            	  2452: 	RTS
                            	  2453: 
                            	  2454: 
                            	  2455: IDEwr8D_X:					;WRITE Data in [DH] to IDE register @ [DL]
01:000914FA 13FC008000FF0033	  2456: 	MOVE.B	#WRITEcfg8255,IDECtrlPort	;Set 8255 to write mode
                            	  2457: 	
01:00091502 13C400FF0031    	  2458: 	MOVE.B	D4,IDEportB			;Get data and put it in 8255 >>>> Port B <<<< 
                            	  2459: 	
01:00091508 13C500FF0032    	  2460: 	MOVE.B	D5,IDEportC			;Select IDE register, drive address onto control lines
                            	  2461: 	
01:0009150E 0039002000FF0032	  2462: 	OR.B	#IDEwrline,IDEportC			;Assert write pin
                            	  2463: 	
01:00091516 13C500FF0032    	  2464: 	MOVE.B	D5,IDEportC			;Select IDE register, drive address onto control lines
                            	  2465: 
01:0009151C 13FC000000FF0032	  2466: 	MOVE.B	#0,IDEportC			;Zero all port C lines
                            	  2467: 	
01:00091524 13FC009200FF0033	  2468: 	MOVE.B	#READcfg8255,IDECtrlPort	;Config 8255 chip, read mode on return
01:0009152C 4E75            	  2469: 	RTS
                            	  2470: 
                            	  2471: 
                            	  2472: 
                            	  2473: ;----------------------- Routine to download from a PC via XMODEM a .bin file ----------------------------------------
                            	  2474: 			
                            	  2475: XMODEM_BIN: 		;Download an XModem .bin file.  Note some registers changed (not A0 and A1)
01:0009152E 45FA16BC        	  2476:  	LEA	MODEM_BIN_SIGNON,A2	;Will show message explaining we are about to upload a .bin file
01:00091532 6100040E        	  2477: 	BSR	PRINT_STRING
                            	  2478: 
01:00091536 13FC000000098515	  2479: 	MOVE.B	#0,(RECVD_SECT_NO)
01:0009153E 13FC000000098516	  2480: 	MOVE.B	#0,(SECTNO)
01:00091546 13FC000000098517	  2481: 	MOVE.B	#0,(ERRCT)
                            	  2482: 	
01:0009154E 610004D8        	  2483: 	BSR	SERIAL_INITILIZE_A	;RESET THE ZILOG SCC
                            	  2484: 					
01:00091552 45FA171C        	  2485: 	LEA	RAM_DESTINATION_MSG,A2	;Ask for destination
01:00091556 610003EA        	  2486: 	BSR	PRINT_STRING
01:0009155A 610001EC        	  2487: 	BSR	GETLONG_D7	;Get start address
01:0009155E B43C000D        	  2488: 	CMP.B	#CR,D2	;Is it valid - must end with CR
01:00091562 66000424        	  2489: 	BNE	ERROR	;From there BRA to LOOP
01:00091566 2647            	  2490: 	MOVE.L	D7,A3	;<<< Save RAM address in A3
01:00091568 610003E6        	  2491: 	BSR	CRLF
                            	  2492: 
01:0009156C 24381F40        	  2493: 	MOVE.L	SERIAL_RETRYS,D2	;Number of times to try reading serial port before aborting.
01:00091570 61000376        	  2494: 	BSR	RECV
                            	  2495: 
01:00091574 45FA18B3        	  2496: 	LEA	START_B_POINTER_MSG,A2	;"Will load .bin file data starting at RAM location "
01:00091578 610003C8        	  2497: 	BSR	PRINT_STRING
01:0009157C 2E0B            	  2498: 	MOVE.L	A3,D7
01:0009157E 61000266        	  2499: 	BSR	PUTLONG_D7	;Show current address
01:00091582 610003CC        	  2500: 	BSR	CRLF
                            	  2501: 	
01:00091586 45FA171F        	  2502: 	LEA	DOWNLOAD_MSG,A2	;Speak "Downloading file"
01:0009158A 6100045E        	  2503: 	BSR	SPEAK_STRING
                            	  2504: 
                            	  2505: RECV_LOOP:			;<<< MAIN RECIEVE LOOP >>>>
01:0009158E 4202            	  2506: 	CLR.B	D2	;GET 0
01:00091590 13C200098517    	  2507: 	MOVE.B	D2,(ERRCT)	;Start error count with 0
                            	  2508: RECV_HDR:
01:00091596 45FA1729        	  2509: 	LEA	RMSG,A2	;Reading sector message
01:0009159A 610003A6        	  2510: 	BSR	PRINT_STRING
01:0009159E 1C3A6F76        	  2511: 	MOVE.B	(SECTNO),D6	;Show current sector number
01:000915A2 5206            	  2512: 	ADD.B	#1,D6
01:000915A4 61000280        	  2513: 	BSR	PUTBYTE_D6
01:000915A8 45FA17E8        	  2514: 	LEA	RAM_MSG,A2	;"H.  IF OK, will write to RAM location"
01:000915AC 61000394        	  2515: 	BSR	PRINT_STRING
01:000915B0 2E0B            	  2516: 	MOVE.L	A3,D7
01:000915B2 61000232        	  2517: 	BSR	PUTLONG_D7	;Show current address
01:000915B6 45FA1903        	  2518: 	LEA	H_MSG,A2
01:000915BA 61000386        	  2519: 	BSR	PRINT_STRING
                            	  2520: 
01:000915BE 243C00027100    	  2521: 	MOVE.L	#20*SERIAL_RETRYS,D2	;Number of times to try reading serial port before aborting.
01:000915C4 61000322        	  2522: 	BSR	RECV	;Get character from modem serial port
01:000915C8 B43C00FF        	  2523: 	CMP.B	#$FF,D2	;Return with FF in D2 if all is OK
01:000915CC 6750            	  2524: 	BEQ	RHNTO	;WE ARE OK, NO TIMEOUT
                            	  2525: 
                            	  2526: RECV_HDR_TIMEOUT:
01:000915CE 45FA1765        	  2527: 	LEA	TOUTM,A2	;PRINT TIMEOUT MESSAGE
01:000915D2 6100036E        	  2528: 	BSR	PRINT_STRING
01:000915D6 1C3A6F3F        	  2529: 	MOVE.B	(ERRCT),D6	;Show error count as well
01:000915DA 6100024A        	  2530: 	BSR	PUTBYTE_D6
01:000915DE 61000370        	  2531: 	BSR	CRLF
                            	  2532: 
                            	  2533: RECV_SECT_ERR:		;PURGE THE LINE OF INPUT CHARS
01:000915E2 243C00001F40    	  2534: 	MOVE.L	#SERIAL_RETRYS,D2	;Number of times to try reading serial port before aborting.
01:000915E8 610002FE        	  2535: 	BSR	RECV
01:000915EC 4A02            	  2536: 	TST.B	D2
01:000915EE 66F2            	  2537: 	BNE	RECV_SECT_ERR	;LOOP UNTIL SENDER DONE
                            	  2538: 	
01:000915F0 123C0015        	  2539: 	MOVE.B	#NAK,D1
01:000915F4 610002BC        	  2540: 	BSR	SERIAL_OUT	;SEND NAK
                            	  2541: 	
01:000915F8 1C3A6F1D        	  2542: 	MOVE.B	(ERRCT),D6	;Inc Error Count (ERRCT)
01:000915FC 5206            	  2543: 	ADD.B	#1,D6
01:000915FE 13C600098517    	  2544: 	MOVE.B	D6,(ERRCT)
01:00091604 BC3C0008        	  2545: 	CMP.B	#MODEM_ERR_LIMIT,D6	;Currently set for 5 trys
01:00091608 6F8C            	  2546: 	BLE	RECV_HDR	;Go try again
                            	  2547: 	
01:0009160A 610000FC        	  2548: 	BSR	CHECK_FOR_QUIT
01:0009160E 4A01            	  2549: 	TST.B	D1
01:00091610 6784            	  2550: 	BEQ	RECV_HDR	;Try again
01:00091612 45FA17EE        	  2551: 	LEA	BAD_HEADER,A2	;'Unable to get a valid file header!'
01:00091616 6100032A        	  2552: 	BSR	PRINT_STRING
01:0009161A 600000E2        	  2553: 	BRA	MODEM_DONE	;Abort back to Monitor start
                            	  2554: 
