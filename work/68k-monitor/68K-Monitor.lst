01:00091640 61000300        	  2566: 	BSR	PRINT_STRING
01:00091644 609C            	  2567: 	BRA	RECV_SECT_ERR
                            	  2568: 
                            	  2569: GOT_SOH:			;We got correct SOH so now get data
01:00091646 243C00001F40    	  2570: 	MOVE.L	#SERIAL_RETRYS,D2	;Number of times to try reading serial port before aborting.
01:0009164C 6100029A        	  2571: 	BSR	RECV
