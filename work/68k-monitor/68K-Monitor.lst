                            	   689: VERIFY_RAM:			;M Command. Verify two RAM locations have the same data
01:000903EA 6100135C        	   690: 	BSR	GETLONG_D7	;Get start address
01:000903EE B43C002C        	   691: 	CMP.B	#',',D2	;Is it valid
