                            	  1703: 
01:00090DBC 45FA1CC8        	  1704: 	LEA	COPY_ERR,A2	;Indicate an error
01:00090DC0 61000B80        	  1705: 	BSR	PRINT_STRING
01:00090DC4 61000254        	  1706: 	BSR	SHOW_TRACK_SEC	;Show current location of error
01:00090DC8 61000B86        	  1707: 	BSR	CRLF
01:00090DCC 6016            	  1708: 	BRA	COPY_OK3
                            	  1709: 
                            	  1710: COPY_OK1:
