01:000918A8 1210            	  2875: GETSTAT:	MOVE.B	(A0),D1	;Get a keyboard status in D1, Z= nothing, 2 = char present
01:000918AA 02010002        	  2876: 	ANDI.B	#$02,D1
01:000918AE 4A01            	  2877: 	TST.B	D1
01:000918B0 4E75            	  2878: 	RTS
