01:00091A4C 1A1B            	  3068: SCC_2:   	MOVE.B	(A3)+,D5	;Table of Zilog SCC Initilization values
01:00091A4E 1485            	  3069: 	MOVE.B	D5,(A2)	;Program the SCC Channel B (A1,A3 or 10,12H) for 19K Baud
01:00091A50 5302            	  3070: 	SUB.B	#1,D2	;All 14 values
01:00091A52 4A02            	  3071: 	TST.B	D2
