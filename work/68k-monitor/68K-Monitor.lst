                            	   694: 	
01:000903F8 6100134E        	   695: 	BSR	GETLONG_D7	;End address
01:000903FC B43C002C        	   696: 	CMP.B	#',',D2	;Is it valid
01:00090400 66001586        	   697: 	BNE	ERROR
