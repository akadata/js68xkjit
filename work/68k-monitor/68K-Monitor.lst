01:0009199C 2F0B            	  2992: SPEAKOUT:	MOVE.L	A3,-(A7)	;> Save A3
01:0009199E 2F02            	  2993: 	MOVE.L	D2,-(A7)	;> Save D2
01:000919A0 2F03            	  2994: 	MOVE.L	D3,-(A7)	;> Save D3
01:000919A2 243C000000FF    	  2995: 	MOVE.L	#255,D2	;Will try 255 times, then timeout
01:000919A8 267C00FF00A0    	  2996: 	MOVE.L	#BCTL,A3
01:000919AE 2613            	  2997: SOUT1:	MOVE.L	(A3),D3
01:000919B0 02030004        	  2998: 	ANDI.B	#$04,D3
01:000919B4 660C            	  2999: 	BNE	SENDS
01:000919B6 5302            	  3000: 	SUB.B	#1,D2
01:000919B8 66F4            	  3001: 	BNE	SOUT1
01:000919BA 261F            	  3002: SOUT2:	MOVE.L	(A7)+,D3	;< Restore D3
01:000919BC 241F            	  3003: 	MOVE.L	(A7)+,D2	;< Restore D2
01:000919BE 265F            	  3004: 	MOVE.L	(A7)+,A3	;< Restore A3
01:000919C0 4E75            	  3005: 	RTS
                            	  3006: 
01:000919C2 267C00FF00A2    	  3007: SENDS:	MOVE.L	#BDTA,A3
01:000919C8 1681            	  3008: 	MOVE.B	D1,(A3)	;Send actual character to data port
                            	  3009: ;	BSR	PUTCHAR	;<---- For debugging, display character ---
01:000919CA 263C000003E8    	  3010: 	MOVE.L	#SPEAKER_DELAY,D3	;For some reason we need this delay
01:000919D0 5383            	  3011: SENDS1:	SUB.L	#1,D3	;If not characters get dropped!
01:000919D2 4A83            	  3012: 	TST.L	D3
01:000919D4 66FA            	  3013: 	BNE	SENDS1
01:000919D6 163C0005        	  3014: 	MOVE.B	#5,D3	;Sel register 5
01:000919DA 267C00FF00A0    	  3015: 	MOVE.L	#BCTL,A3	;Raise RTS line to prevent the next character arriving
01:000919E0 1683            	  3016: 	MOVE.B	D3,(A3)
01:000919E2 163C00E8        	  3017: 	MOVE.B	#$E8,D3
01:000919E6 1683            	  3018: 	MOVE.B	D3,(A3)
01:000919E8 60D0            	  3019: 	BRA	SOUT2
