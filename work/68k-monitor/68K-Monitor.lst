01:00090DE8 61000B58        	  1722: 	BSR	PRINT_STRING
01:00090DEC 61000AA6        	  1723: 	BSR	GETCHAR
01:00090DF0 B23C001B        	  1724: 	CMP.B	#ESC,D1
01:00090DF4 6616            	  1725: 	BNE	C_NEXTSEC1
01:00090DF6 123C0000        	  1726: C_DONE:	MOVE.B	#0,D1	;Login drive A:
01:00090DFA 6100FAEA        	  1727: 	BSR	SELECT_DRIVE
01:00090DFE 13C10009850F    	  1728: 	MOVE.B	D1,(CURRENT_IDE_DRIVE)
01:00090E04 61000B4A        	  1729: 	BSR	CRLF	
01:00090E08 6000FA46        	  1730: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1731: 	
                            	  1732: C_NEXTSEC1:
