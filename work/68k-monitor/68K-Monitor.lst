                            	  1093: PATCH:			;Y Command, Quick patch to move RAM 4000H-9000H to F4000H & JUMP to it
01:000907B6 45FA18BB        	  1094: 	LEA	PATCH_MSG,A2	;"Moving Code 4000H-9000H to F4000H, Then jump to that location"
01:000907BA 61001186        	  1095: 	BSR	PRINT_STRING	;The CPM3/Z80 SID program will place any test .bin file from a disk to 4000H 
                            	  1096: 			;in RAM (no matter what its final ORG is). 
01:000907BE 367C4000        	  1097: 	MOVE.L	#$4000,A3	;This command will then move test versions of this monitor (or any other
01:000907C2 2A7C000F4000    	  1098: 	MOVE.L	#$F4000,A5	;program) up out of the way to F4000H and execute it from there.
01:000907C8 223C00008000    	  1099: 	MOVE.L	#$8000,D1	;This shold be large enough for a monitor copy
                            	  1100: 	
01:000907CE 1ADB            	  1101: PATCH1:	MOVE.B	(A3)+,(A5)+
01:000907D0 5381            	  1102: 	SUBQ.L	#1,D1
01:000907D2 66FA            	  1103: 	BNE	PATCH1
01:000907D4 4EF900F40000    	  1104: 	JMP	Patch_RAM	;Jump to this loction
                            	  1105: 	
