Source: "work/68k-monitor/68K-Monitor.work.s"
                            	     1: *-----------------------------------------------------------
                            	     2: * Program Number: 68K Monitor for S100Computers.com
                            	     3: * Written by    : John Monahan
                            	     4: * Date Created  : 11/11/2011
                            	     5: * Description   : Basic monitor for 68K S-100 board
                            	     6: *
                            	     7: *   'A=Memmap    C=XMODEM(Bin) D=Disp RAM    E=Echo        F=Fill RAM'
                            	     8: *   'G=Goto RAM  H=Math        I=Time        K=Menu        L=Test Ints'
                            	     9: *   'M=Move RAM  N=IDE Menu    Q=Port I/O    U=Serial Test S=Subs RAM'
                            	    10: *   'T=Type RAM  V=Verify RAM  X=Signals     Y=Patch       Z=Back to Z80'
                            	    11: *
                            	    12: *-----------------------------------------------------------
                            	    13: ; 	V1.5	03/07/2012	;Corrected line length display of RAM (D & T Commands)
                            	    14: ;	V1.6	03/07/2012	;Added initilization of Interrupt routines in low RAM
                            	    15: ;	V1.7	03/08/2012	;Add test interrupts routine, "L" CMD.
                            	    16: ;	V1.8	03/09/2012	;Code to switch back to Z80, and hardware signals analysis
                            	    17: ;	V1.9	03/18/2012	;Added IDE Board Diagnostic Section
                            	    18: ;	V1.91	03/27/2012	;Substitute RAM redone
                            	    19: ;	V2.0	04/02/2012	;Added IDE Menu Items and Y command
                            	    20: ;	V2.1	04/26/2013	;Fixed numerous small bugs, RAM display map,D,F,M X commands etc
                            	    21: ;	V2.2	04/27/2013	;Display RAM (D CMD) also displays ASCII
                            	    22: ;	V2.3	04/23/2014	;Allow output to 16 bit ports (>0FFH), DMA1* port switch is now 00EEH
                            	    23: ;	V2.4	04/30/2014	;Cleanup console I/O routines, add serial port I/O
                            	    24: ;	V2.5	05/2/2014	;Added XMODEM .bin file download capabilities over serial port
                            	    25: ;	V2.6	06/12/2014	;Corrected QO/QI port bug
                            	    26: ;           V3.0    7/27/2020               ;Damian Wildie corrections and addition of working IDE/CF card menu    			
                            	    27: 
                            	    28: ;   >>>>>> Please note the IDE Board Diagnostic section is not complete yet. Do NOT use <<<<<<<
                            	    29: 
                            	    30: 
                            	    31: ;Programming a Wellon VP-290 with 28C256 EEPROMS.
                            	    32: ;Assemble and make a S68 file (Project Menu for EASy68K)
                            	    33: ;Load first, even byte in dropdown menu for "File Mode"
                            	    34: ;For "From File Address(Hex) enter FD0000 (Note "To Buffer Address (HEX) is 0)
                            	    35: ;File Size is 8000 (for X28C256's)
                            	    36: ;For "Auto Format Detect" use Motorola S
                            	    37: ;Repeat, for second EEPROM using Odd Bytes for "File Mode"
                            	    38: ;
                            	    39: ;
                            	    40: 
                            	    41: BELL     		EQU     $07
                            	    42: BLANK    		EQU     $20
                            	    43: CR      		EQU     $0D 
                            	    44: LF       		EQU     $0A
                            	    45: ESC      		EQU     $1B
                            	    46: TAB		EQU     $09
                            	    47: SOH		EQU     1	; For Modem etc.
                            	    48: EOT		EQU     4
                            	    49: ACK		EQU     6
                            	    50: NAK		EQU     $15
                            	    51: 
                            	    52: 			;Note, only one of the following 3 equates can be 1
                            	    53: SIMMULATOR		EQU     0	;Set to 1 if using EASy68K Simmulator (Console I/O will be via software interrupts)
                            	    54: S100_TEST		EQU     0	;Set to 1 if using S100 RAM (We will not use INT's for console I/O)
                            	    55: ROM_CODE 		EQU     1	;Set to 1 for ROM code (We will not use INT's for console I/O)
                            	    56: 			
                            	    57: 
                            	    58: ;Propeller Console IO S-100 board or SD SYSTEMS VIDIO BOARD FOR CONSOLE I/O(<---These must configured for your hardware
                            	    59: 
                            	    60: KEYSTAT		EQU     $00DE0004	
                            	    61: KEYIN		EQU     $00DE0000	;Console input port. Normally the Propeller Driven S-100 Console-IO Board
                            	    62: KEYOUT		EQU     $00DE0000	;Console output port. Normally the Propeller Driven S-100 Console-IO Board
                            	    63: 
                            	    64: 
                            	    65: 
                            	    66: ;-------------- THIS IS MY PORT TO OUTPUT DATA TO HP 4050T LASAR PRINTER  (IMSAI 8PIO Board)
                            	    67: 
                            	    68: PRINTER_STATUS	EQU     $00FF0005	;IN, HP PARRELL PORT
                            	    69: PRINTER_OUT		EQU     $00FF0005	;OUT
                            	    70: PRINTER_STROBE	EQU     $00FF0004	;OUT
                            	    71: DIAG_LEDS		EQU     $00FF0005	;OUT (Will use this port initially for diagnostic LED display)
                            	    72: 
                            	    73: 
                            	    74: ;-------------- S100Computers Serial I/O BOARD PORT ASSIGNMENTS  (A0-AC)
                            	    75: 
                            	    76: BCTL		EQU     $00FF00A0	;CHANNEL B CONTROL PORT ASSIGNMENTS OF THE ZILOG SCC CHIP  
                            	    77: ACTL		EQU     $00FF00A1	;CHANNEL A CONTROL (Base Port)		
                            	    78: BDTA		EQU     $00FF00A2	;CHANNEL B DATA
                            	    79: ADTA		EQU     $00FF00A3	;CHANNEL A DATA
                            	    80: MODEM_ERR_LIMIT	EQU     8	;Max number of Modem serial port re-reads aborting (See XMODEM_BIN)
                            	    81: SERIAL_RETRYS	EQU     8000	;Default number of times to try reading serial port before aborting. Not critical.
                            	    82: SPEAKER_DELAY	EQU     1000	;Slight delay for speak sysnthesizer	
                            	    83: ;
                            	    84: PortA_8255		EQU     $00FF00A8	;A port of 8255 ;<--- Adjust as necessary
                            	    85: PortB_8255		EQU     $00FF00A9	;B port of 8255
                            	    86: PortC_8255		EQU     $00FF00AA	;C Port of 8255
                            	    87: PortCtrl_8255 	EQU     $00FF00AB	;8255 configuration port
                            	    88: 
                            	    89: AinBout8255cfg	EQU     %10011000	;Set 8255 ports:- A input, B output, 
                            	    90: 			;C(bits 0-3) output, (bits 4-7)input
                            	    91: 
                            	    92: USB_DATA		EQU     $00FF00AC	;PORT ASSIGNEMENT FOR DLP-USB Controller chip
                            	    93: USB_STATUS		EQU     $00FF00AA	;Status port for USB port (Port C of 8255, bits 6,7)
                            	    94: 
                            	    95: USB_RXE		EQU     $80	;If Bit 7 = 0, data available to recieve by S-100 Computer	
                            	    96: USB_TXE		EQU     $40	;If Bit 6 = 0 data CAN be written for transmission to PC
                            	    97: 
                            	    98: IOBYTE		EQU     $00FF00EF	;IOBYTE Port on S100Computers SMB Board.
                            	    99: 
                            	   100: ; BIT MAP OF PORT 0EFH:- X X X X  X X X X      (11111111=NORMAL CONFIG)
                            	   101: ;			 | | | |  | | | |..For Z80 Monitor,		0=CONSOLE DATA TO PRINTER ALSO
                            	   102: ;			 | | | |  | | |....For 8086 Monitor,	0=Force MSDOS Consol output to CGA/VGA Board instead of Propeller board
                            	   103: ;			 | | | |  | |......For 8086 Monitor,	0=Do not initilize extra ROMS
                            	   104: ;			 | | | |  |........For 8086 Monitor,	0=Debug data for all MSDOS 10H & 15H INT's to Serial Port and external display
                            	   105: ;			 | | | |...........Unused			
                            	   106: ;			 | | |-------------For Monitor,	        0=Consol Output,(not input), via ACIA Serial port on S100Computers Serial-I
                            	   107: ;			 | |...............For CPM3,		    0=Force reformat of Memory disk upon any CPM3 cold re-boot
                            	   108: ;                                            |
                            	   109: ;			 |.................For CPM3,		    0=Write protect Memory disk for CPM3
                            	   110: ;					            For 8086 Monitor    0=Prevent doing a JMPF to 500H after 8086 reset (to CPM86 boot)
                            	   111: ;								Normally a test is made to see if the CPM86 Boot is already in RAM at 500H
                            	   112: ;								If it is, a 8086 reset will bypass the monitor and go directly there. 
                            	   113: ;								(see Init: in 8086 Monitor)
                            	   114: ;
                            	   115: ;		Note if IOBYTE = 00xxxxxx,					This will force the 8086 hardware diagnostic test after reset. 
                            	   116: ;                                                               (See code at FFFF0H in this 8086 monitor)
                            	   117: 
                            	   118: 
                            	   119: 
                            	   120: ;------------ S100Computers MSDOS BOARD PORT ASSIGNMENTS  
                            	   121: 
                            	   122: NS_EOI		equ     $20	;Non specific end of interrupt command
                            	   123: MASTER_PIC_PORT	equ     $00FF0020	;Hardware port the 8259A is assigned (two ports 20H & 21H)
                            	   124: 
                            	   125: MasterICW1		equ     %00010111	;EDGE triggered, 4 bytes, single Master,ICW4 needed
                            	   126: MasterICW2		equ     $8	;Base address for 8259A Int Table (IBM-PC uses 8X4 = 20H)
                            	   127: MasterICW3		equ     $0	;No slave
                            	   128: MasterICW4		equ     %00000011	;No special mode, non buffer, Auto EOI, 8086.  ;<<<<,
                            	   129: 
                            	   130: CMOS_PORT		EQU     $00FF0070	;Base Port for CMOS Chip
                            	   131: CMOS_VALID		EQU     $00FF000D	;To check DS12887 CMOS chip is present and OK (Note AT-BIOS uses 0EH)
                            	   132: CMOS_REGA		EQU     $00FF000A	;CMOS REGISTER A
                            	   133: 
                            	   134: TIMER		EQU     $00FF0040	;Base port of 8254
                            	   135: TIM_CTL		EQU     $00FF0043
                            	   136: COUNTS_SEC		EQU     $18
                            	   137: COUNTS_MIN		EQU     1092
                            	   138: COUNTS_HOUR		EQU     $07	;Seems this value is used with AT/CMOS chip (was 65543 on PC)
                            	   139: 
                            	   140: UPDATE_TIMER	EQU     $80
                            	   141: 
                            	   142: CMOS_SECONDS	EQU     $0	;RAM offsets for CMOS Registers
                            	   143: CMOS_MINUTES	EQU     $2
                            	   144: CMOS_HOURS		EQU     $4
                            	   145: 
                            	   146: 
                            	   147:    IFEQ SIMMULATOR		;If SIMMULATOR = 0 (Normal EEPROM)
                            	   148: Patch_RAM		EQU    $00F40000	;Location of Patch code area
                            	   149:    ENDC
                            	   150: 
                            	   151:    IFNE SIMMULATOR		;If SIMMULATOR = 1 (For testing here within EASy68K & S100 RAM)
                            	   152: Patch_RAM		EQU    $00008000	
                            	   153:    ENDC	
                            	   154:   
                            	   155: 	
                            	   156: ;-------------- S100Computers IDE BOARD PORT ASSIGNMENTS  (30-34H)
                            	   157: 
                            	   158: ;Ports for 8255 chip. Change these to specify where the 8255 is addressed,
                            	   159: ;and which of the 8255's ports are connected to which IDE signals.
                            	   160: ;The first three control which 8255 ports have the IDE control signals,
                            	   161: ;upper and lower data bytes.  The forth one is for mode setting for the
                            	   162: ;8255 to configure its ports, which must correspond to the way that
                            	   163: ;the first three lines define which ports are connected.
                            	   164: 
                            	   165: IDEportA		EQU     $00FF0030	;lower 8 bits of IDE interface
                            	   166: IDEportB		EQU     $00FF0031	;upper 8 bits of IDE interface
                            	   167: IDEportC		EQU     $00FF0032	;control lines for IDE interface
                            	   168: IDECtrlPort		EQU     $00FF0033	;8255 configuration port
                            	   169: IDEDrivePort	EQU     $00FF0034	;To select the 1st or 2nd CF card/drive
                            	   170: 
                            	   171: IDE_Reset_Delay	EQU     $20	;Time delay for reset/initilization (~66 uS, with 8MHz 8086, 1 I/O wait state)
                            	   172: 
                            	   173: READcfg8255		EQU     %10010010	;Set 8255 IDEportC out, IDEportA/B input
                            	   174: WRITEcfg8255	EQU     %10000000	;Set all three 8255 ports output
                            	   175: 
                            	   176: ;IDE control lines for use with IDEportC.  
                            	   177: 
                            	   178: IDEa0line		EQU     $01	;direct from 8255 to IDE interface
                            	   179: IDEa1line		EQU     $02	;direct from 8255 to IDE interface
                            	   180: IDEa2line		EQU     $04	;direct from 8255 to IDE interface
                            	   181: IDEcs0line		EQU     $08	;inverter between 8255 and IDE interface
                            	   182: IDEcs1line		EQU     $10	;inverter between 8255 and IDE interface
                            	   183: IDEwrline		EQU     $20	;inverter between 8255 and IDE interface
                            	   184: IDErdline		EQU     $40	;inverter between 8255 and IDE interface
                            	   185: IDErstline		EQU     $80	;inverter between 8255 and IDE interface
                            	   186: ;
                            	   187: ;Symbolic constants for the IDE Drive registers, this makes the
                            	   188: ;code more readable than always specifying the address pins
                            	   189: 
                            	   190: REGdata		EQU     IDEcs0line
                            	   191: REGerr		EQU     IDEcs0line+IDEa0line
                            	   192: REGseccnt		EQU     IDEcs0line+IDEa1line
                            	   193: REGsector	 	EQU     IDEcs0line+IDEa1line+IDEa0line
                            	   194: REGcylinderLSB	EQU     IDEcs0line+IDEa2line
                            	   195: REGcylinderMSB	EQU     IDEcs0line+IDEa2line+IDEa0line
                            	   196: REGshd		EQU     IDEcs0line+IDEa2line+IDEa1line	;(0EH)
                            	   197: REGcommand		EQU     IDEcs0line+IDEa2line+IDEa1line+IDEa0line	;(0FH)
                            	   198: REGstatus		EQU     IDEcs0line+IDEa2line+IDEa1line+IDEa0line
                            	   199: REGcontrol		EQU     IDEcs1line+IDEa2line+IDEa1line
                            	   200: REGastatus		EQU     IDEcs1line+IDEa2line+IDEa1line+IDEa0line
                            	   201: 
                            	   202: ;IDE Command Constants.  These should never change.
                            	   203: 
                            	   204: COMMANDrecal	EQU     $10
                            	   205: COMMANDread		EQU     $20
                            	   206: COMMANDwrite	EQU     $30
                            	   207: COMMANDinit		EQU     $91
                            	   208: COMMANDid		EQU     $EC
                            	   209: COMMANDspindown 	EQU     $E0
                            	   210: COMMANDspinup	EQU     $E1
                            	   211: ;
                            	   212: ; IDE Status Register:
                            	   213: ;  bit 7: Busy	1=busy, 0=not busy
                            	   214: ;  bit 6: Ready 	1=ready for command, 0=not ready yet
                            	   215: ;  bit 5: DF	1=fault occured on the IDE drive
                            	   216: ;  bit 4: DSC	1=seek complete
                            	   217: ;  bit 3: DRQ	1=data request ready, 0=not ready to xfer yet
                            	   218: ;  bit 2: CORR	1=correctable error occured
                            	   219: ;  bit 1: IDX	vendor specific
                            	   220: ;  bit 0: ERR	1=error occured
                            	   221: 
                            	   222: MAXSEC		EQU      $3D	;Sectors per track for CF my Memory drive, Kingston CF 8G. (CPM format, 0-3CH)
                            	   223: 			;translates to LBA format of 1 to 3D sectors, for a total of 61 sectors/track.
                            	   224: 			;This CF card actully has 3F sectors/track. Will use 3D for my CPM86 system because
                            	   225: 			;my Seagate drive has 3D sectors/track. Don't want different CPM86.SYS files around
                            	   226: 			;so this program will also work with a Seagate 6531 IDE drive
                            	   227: 
                            	   228: DOS_MAXSEC	 	EQU      $3F	;For MS-DOS BIOS Setting "Hard Disk" to Custom type (CF Card, 63 Sectors/track)
                            	   229: DOS_MAXHEADS	EQU      $10	;16 head(s)
                            	   230: DOS_MAXCYL_L	EQU      $FF	;Low Byte maximum cylinder (sent via INT 13H's in CH)
                            	   231: DOS_MAXCYL		EQU      1024	;Max cylinders
                            	   232: DOS_MAXSEC_CYL	EQU      $FF	;3FH, maximum sector number (bits 5-0)+ two Cyl High Bits (Sectors numbered 1....x)
                            	   233: 
                            	   234: 
                            	   235: 
                            	   236: ;--------------Other Hardware Equates --------------------------------------------------------- 
                            	   237: 
                            	   238: HOLD_STATE		EQU      $80	;Set Keyboard flag to indicate a Pause is required
                            	   239: NO_HOLD_STATE	EQU      $7F	;To clear the above flag
                            	   240: 
                            	   241: SW68K 		EQU      $00FF00EE	;OUTPUT TO THIS PORT 02H, SWITCHES THE 68000 CPU BACK to the Z80 in hardware
                            	   242: 			;In my system using the V2 SMB.
                            	   243: 
                            	   244: 
                            	   245: ;------------------ START --------------------------------------------------------------------------------
                            	   246: 
                            	   247: 
                            	   248: 
                            	   249: 
                            	   250:    IFNE ROM_CODE		;If ROM_CODE = 1 (Use with ROM)
                            	   251: 	ORG	$00090000
                            	   252: 	
00:00090000 00098100        	   253: 	DC.L	$00098100	;SSP = guest RAM base
00:00090004 00090020        	   254: 	DC.L	$00090020	;PC = guest entry point
                            	   255: 
                            	   256: 	ORG	$00090020	;Will start monitor here in guest image
                            	   257:    ENDC
                            	   258:    
                            	   259:    IFNE SIMMULATOR		;If SIMMULATOR = 1 (Use for testing in EASy68K simulator)
                            	   260: 	ORG	$00000000
                            	   261: 	BRA	SKIP	;jump up to 1000H because Int vectors will overwrite code here
                            	   262: 	
                            	   263: 	ORG	$1000	;In both EASy68K and S100 test modes will place code at 1000H
                            	   264: SKIP:
                            	   265:    ENDC	
                            	   266:  
                            	   267:      IFNE S100_TEST		;If SIMMULATOR = 1 (Use for testing, for S100 RAM use the ROM stack)
                            	   268: 	ORG	$00000000
                            	   269: 	BRA	SKIP	;jump up to 1000H because Int vectors will overwrite code here
                            	   270: 	
                            	   271: 	ORG	$1000	;In both EASy68K and S100 test modes will place code at 1000H
                            	   272: SKIP:
                            	   273:    ENDC	
                            	   274: 
