                            	  1666: ;---------------- Copy Drive A: to Drive B:  ------------------------------
                            	  1667: COPY_AB:			
01:00090D54 45FA1C71        	  1668: 	LEA	DiskCopyMsg,A2
01:00090D58 61000BE8        	  1669: 	BSR	PRINT_STRING
01:00090D5C 61000B36        	  1670: 	BSR	GETCHAR
01:00090D60 61000C14        	  1671: 	BSR	TOUPPER
01:00090D64 B23C0059        	  1672: 	CMP.B	#'Y',D1
01:00090D68 6704            	  1673: 	BEQ	COPY_AB1
01:00090D6A 6000008A        	  1674: 	BRA	C_DONE
