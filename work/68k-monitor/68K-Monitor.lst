                            	  1743: ;-------------- Verify Drive A: = B: ------------------------------
                            	  1744: VERIFY_AB:		
01:00090E20 45FA1BD8        	  1745: 	LEA	DiskVerifyMsg,A2
01:00090E24 61000B1C        	  1746: 	BSR	PRINT_STRING
                            	  1747: 	
01:00090E28 13FC00000009850D	  1748: 	MOVE.B	#0,(RAM_SEC)	;Start with CPM sector 0
01:00090E30 13FC00000009850E	  1749: 	MOVE.B	#0,(RAM_TRK)	;Start with CPM Track 0
                            	  1750: 	
01:00090E38 61000B16        	  1751: 	BSR	CRLF
01:00090E3C 61000B12        	  1752: 	BSR	CRLF
                            	  1753: 	
                            	  1754: NextVCopy:
