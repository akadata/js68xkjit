                            	  2828: ;---------------------------- MAIN ROUTINE TO PRINT A CHARACTER ON CONSOLE --------------------------
                            	  2829: 
                            	  2830: 			;Send ASCII character in D1
                            	  2831: PUTCHAR:	
                            	  2832:    IFNE SIMMULATOR		;If SIMMULATOR = 1, then send character via software int
                            	  2833: 	MOVE	#6,D0	;Send a character (in D1), to CRT
                            	  2834: 	TRAP	#15
                            	  2835: 	RTS
                            	  2836:    ENDC
                            	  2837: 
                            	  2838:   IFEQ SIMMULATOR		;If SIMMULATOR = 0, then send via console I/O port (or serial port)
01:00091882 2F05            	  2839:  	MOVE.L	D5,-(A7)	;> Save D5	
01:00091884 1A10            	  2840: PUTCHAR0:	MOVE.B	(A0),D5	;Check UART status is ready to receive character
01:00091886 02050001        	  2841: 	ANDI.B	#$01,D5
01:0009188A 4A05            	  2842: 	TST.B	D5
01:0009188C 67F6            	  2843: 	BEQ	PUTCHAR0
01:0009188E 1281            	  2844: 	MOVE.B  D1,(A1)	;Output ASCII (in D1) to UART data port
01:00091890 2A1F            	  2845: 	MOVE.L	(A7)+,D5	;< Restore D5
01:00091892 4E75            	  2846: 	RTS		;Return from subroutine
                            	  2847:    ENDC
                            	  2848: 
                            	  2849: 
                            	  2850: 
                            	  2851: ;---------------------------- MAIN ROUTINE TO GET A CHARACTER FROM CONSOLE --------------------------
                            	  2852: 
                            	  2853: 			;A0 has console status port, A1 has console data port
                            	  2854: GETCHAR:
                            	  2855:    IFNE SIMMULATOR		;If SIMMULATOR = 1, then echo character via software int
                            	  2856: 	MOVE.B	#5,D0	;Get a character from keyboard, put in D1 (NOTE will be echoed)
                            	  2857: 	TRAP	#15
                            	  2858:  	RTS
                            	  2859: 
                            	  2860:   ENDC
                            	  2861:    
                            	  2862:    IFEQ SIMMULATOR		;If SIMMULATOR = 0, then echod character via PUTCHAR 
01:00091894 2F05            	  2863: 	MOVE.L	D5,-(A7)	;> Save D5
01:00091896 1A10            	  2864: GETCHAR0:	MOVE.B	(A0),D5	;Get a keyboard character in D1
01:00091898 02050002        	  2865: 	ANDI.B	#$02,D5
01:0009189C 4A05            	  2866: 	TST.B	D5	;Are we ready
01:0009189E 67F6            	  2867: 	BEQ	GETCHAR0
01:000918A0 1211            	  2868: 	MOVE.B  (A1),D1	;Get ASCII (in D1) from hardware port 01H
01:000918A2 61DE            	  2869: 	BSR	PUTCHAR	;Echo it on console
01:000918A4 2A1F            	  2870: 	MOVE.L	(A7)+,D5	;< Restore D5
01:000918A6 4E75            	  2871: 	RTS		;Return from subroutine, char in D1
                            	  2872:    ENDC
                            	  2873: 
