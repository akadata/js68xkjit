01:00090020 207C00DE0004    	   276: 	MOVE.L	#KEYSTAT,A0	;Point to status Port 0H (CRT, Propeller Console IO Board)
01:00090026 227C00DE0000    	   277: 	MOVE.L	#KEYIN,A1	;Point to hardware Port 01H (CRT, Propeller Console IO Board)
                            	   278: START:			
01:0009002C 45FA1B1A        	   279: 	LEA	Signon,A2	;Show we are alive
01:00090030 61001910        	   280: 	BSR	PRINT_STRING
                            	   281:     
01:00090034 610019F2        	   282:    	BSR	SERIAL_INITILIZE_A	;Initilize Consoel-IO board Serial Port A
01:00090038 61001A06        	   283:   	BSR	SERIAL_INITILIZE_B	;Initilize Consoel-IO board Serial Port B
01:0009003C 45FA1C4F        	   284: 	LEA	SMSG,A2	
                            	   285: ;	BSR	SPEAK_STRING	;Speak out signon the message
                            	   286: 
01:00090040 61000504        	   287: 	BSR	LOW_RAM_INITILIZE	;Initilize low RAM Int Vectors (for all modes)
                            	   288:  
                            	   289: 			;Initilize HIGH RAM to 0  (Used by IDE Routines)
01:00090044 247C00098100    	   290: 	MOVEA.L #BeginRAM,A2	;START OF WORK RAM (PAST STACK)
01:0009004A 203C0000041C    	   291:          	MOVE.L  #(EndRAM-BeginRAM),D0 	;BYTES TO ZERO
01:00090050 7200            	   292:        	CLR.L   D1
                            	   293:         	
01:00090052 14C1            	   294: ZERO_RAM:   MOVE.B  D1,(A2)+       	;ZERO MEMORY
01:00090054 5380            	   295:         	SUBQ.L  #1,D0
01:00090056 66FA            	   296:          	BNE     ZERO_RAM
                            	   297:    
                            	   298:    
01:00090058 45FA1B1F        	   299: LOOP:	LEA	Prompt,A2	;Show CR,LF,'>'
01:0009005C 610018E4        	   300: 	BSR	PRINT_STRING
01:00090060 7200            	   301: 	CLR.L	D1	;Just to be on the safe side
01:00090062 61001830        	   302: 	BSR	GETCHAR	;Get a menu character (WITH ECHO)
01:00090066 6100190E        	   303: 	BSR	TOUPPER	;Lower case to Upper case for lookup table
                            	   304:    	
01:0009006A B23C0041        	   305: 	CMP.B	#'A',D1
01:0009006E 6D16            	   306:    	BLT	ERR
01:00090070 B23C005A        	   307:    	CMP.B	#'Z',D1
01:00090074 6E10            	   308:    	BGT	ERR
01:00090076 923C0041        	   309:   	SUB.B	#'A',D1
01:0009007A E589            	   310:     	LSL.L	#2,D1	;X4 for offset into table
01:0009007C 45FA19DA        	   311:   	LEA	ctable,A2	;Start of cmd table
01:00090080 26721000        	   312:    	MOVE.L	(A2,D1),A3	;Add X4 offset
01:00090084 4ED3            	   313:    	JMP	(A3)
                            	   314:    	
                            	   315: ;-----------------------------------------------------------------------------------------------------
01:00090086 B23C000D        	   316: ERR:	CMP.B	#CR,D1	;If CR just return
01:0009008A 67CC            	   317: 	BEQ	LOOP
01:0009008C 2F01            	   318: 	MOVE.L	D1,-(A7)	;> Save D1
01:0009008E 45FA1C34        	   319: 	LEA	BadCmdMsg,A2	;Non menu selection
01:00090092 610018AE        	   320: 	BSR	PRINT_STRING
01:00090096 2E1F            	   321: 	MOVE.L	(A7)+,D7	;Put D1 in D7
01:00090098 6100174C        	   322: 	BSR	PUTLONG_D7
01:0009009C 45FA2427        	   323: 	LEA	H_MSG_CRLF,A2	;H, then CR,LF
01:000900A0 610018A0        	   324: 	BSR	PRINT_STRING
01:000900A4 60B2            	   325: 	BRA	LOOP	;Back to start for next command
                            	   326: 	
