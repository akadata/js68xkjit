                            	  1847: 
                            	  1848: 
                            	  1849: 	
                            	  1850: ;------------------ Fill RAM buffer with 0's	
                            	  1851: 
                            	  1852: RAMCLEAR:
01:00090F2A 4201            	  1853: 	CLR.B	D1
                            	  1854: RAM_FILL:				
01:00090F2C 45FA71D2        	  1855: 	LEA	IDE_BUFFER,A2
01:00090F30 343C0200        	  1856: 	MOVE.W	#512,D2	;512 bytes total
01:00090F34 14C1            	  1857: CLEAR1:	MOVE.B	D1,(A2)+
01:00090F36 5342            	  1858: 	SUBQ.W	#1,D2
01:00090F38 66FA            	  1859: 	BNE	CLEAR1
                            	  1860: 	
01:00090F3A 45FA1A2B        	  1861: 	LEA	FILL_MSG,A2	
01:00090F3E 61000A02        	  1862: 	BSR	PRINT_STRING
01:00090F42 61000A0C        	  1863: 	BSR	CRLF	
01:00090F46 6000F908        	  1864: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1865: 
                            	  1866: ;----------------  Power up a Hard Disk
                            	  1867: 
01:00090F4A 183C00E1        	  1868: SPINUP:	MOVE.B	#COMMANDspinup,D4
01:00090F4E 1A3C000F        	  1869: spup2:	MOVE.B	#REGcommand,D5
01:00090F52 61000572        	  1870: 	BSR	IDEwr8D
01:00090F56 610004D8        	  1871: 	BSR	IDEwaitnotbusy
01:00090F5A 6C04            	  1872: 	BGE	L_7	
01:00090F5C 600001EE        	  1873: 	BRA	SHOWerrors
01:00090F60 4201            	  1874: L_7:	CLR.B	D1	;Clear carry
01:00090F62 610009EC        	  1875: 	BSR	CRLF	
01:00090F66 6000F8E8        	  1876: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1877: 
                            	  1878: 	
                            	  1879: ;-------------------- Tell the Hard disk to power down
                            	  1880: 
                            	  1881: SPINDOWN:
01:00090F6A 610004C4        	  1882: 	BSR	IDEwaitnotbusy
01:00090F6E 6C04            	  1883: 	BGE	L_8	
01:00090F70 600001DA        	  1884: 	BRA	SHOWerrors
01:00090F74 183C00E0        	  1885: L_8:	MOVE.B	#COMMANDspindown,D4
01:00090F78 60D4            	  1886: 	JMP	spup2
                            	  1887: 
                            	  1888: 
                            	  1889: ;-------------------- Back to parent 8086 Monitor commands
                            	  1890: QUIT_IDE:
01:00090F7A 6000F0DC        	  1891: 	BRA	LOOP	;Back to main Menu
