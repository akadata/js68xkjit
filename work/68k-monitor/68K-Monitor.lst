01:0009041E 66001568        	   710: 	BNE	ERROR
01:00090422 2A47            	   711: 	MOVE.L	D7,A5	;--- Save in A5
                            	   712: 
01:00090424 BB0B            	   713: VERIFY_OK1:	CMP.B	(A3)+,(A5)+
01:00090426 6608            	   714: 	BNE	BAD_MATCH
01:00090428 B9CB            	   715: VERIFY_OK2:	CMP.L	A3,A4	;Are we done yet
01:0009042A 6CF8            	   716: 	BGE	VERIFY_OK1
01:0009042C 6000FC2A        	   717: 	BRA	LOOP
                            	   718: 	
