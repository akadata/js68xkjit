                            	   748: ECHO_ASCII:			;E Command. Get ASCII typed on keyboard and display on Console
01:00090476 45FA1BB8        	   749: 	LEA	ECHO_MSG,A2	;"Will echo each keyboard char on screen"
01:0009047A 610014C6        	   750: 	BSR	PRINT_STRING
                            	   751: 
01:0009047E 610014D0        	   752: 	BSR	CRLF	;New line
01:00090482 7200            	   753: ECHO2:	CLR.L	D1	;Just to be on the safe side
01:00090484 6100140E        	   754: 	BSR	GETCHAR	;get a character
                            	   755: 	
01:00090488 B23C001B        	   756: 	CMP.B	#ESC,D1	;If ESC then we abort
01:0009048C 6700FBCA        	   757: 	BEQ	LOOP
01:00090490 B23C000D        	   758: 	CMP.B	#CR,D1	;If CR then we also abort
01:00090494 6700FBC2        	   759: 	BEQ	LOOP
                            	   760: 
01:00090498 B23C0020        	   761: 	CMP.B	#' ',D1
01:0009049C 6D0C            	   762: 	BLT	NOASCII
01:0009049E B23C007F        	   763: 	CMP.B	#$7F,D1
01:000904A2 6C06            	   764: 	BGE	NOASCII
01:000904A4 610013DC        	   765: ECHO1:	BSR	PUTCHAR	;Echo character
01:000904A8 60D8            	   766: 	BRA	ECHO2
                            	   767: 
01:000904AA 123C002E        	   768: NOASCII:	MOVE.B	#'.',D1
01:000904AE 60F4            	   769: 	BRA	ECHO1
                            	   770: 	
