                            	   774: GOTO_RAM:			;G Command . Go to a location in RAM and start from there.
01:000904B0 61001296        	   775: 	BSR	GETLONG_D7	;Go to address in D7
01:000904B4 B43C000D        	   776: 	CMP.B	#CR,D2	;Is it valid
01:000904B8 660014CE        	   777: 	BNE	ERROR
01:000904BC 2647            	   778: 	MOVE.L	D7,A3	;Save in A3
01:000904BE 4ED3            	   779: 	JMP	(A3)	;That's all there is to it!
