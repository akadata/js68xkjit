01:000919EC 4A01            	  3024: 	CMP.B	#0,D1	
01:000919EE 4A01            	  3025: 	TST.B	D1
01:000919F0 670A            	  3026: 	BEQ	SPEAK_DONE
01:000919F2 B23C000D        	  3027: 	CMP.B	#CR,D1
01:000919F6 6704            	  3028: 	BEQ	SPEAK_DONE
01:000919F8 61A2            	  3029: 	BSR	SPEAKOUT
01:000919FA 60EE            	  3030: 	BRA	SPEAK_STRING
01:000919FC 123C000D        	  3031: SPEAK_DONE:	MOVE.B	#CR,D1	;Flush speaker que
01:00091A00 609A            	  3032: 	BRA	SPEAKOUT
01:00091A02 4E75            	  3033: 	RTS
