                            	  1108: ;**********************************************************************************************************
                            	  1109: ;       
                            	  1110: ;       Module to Test and diagnose the www.S100Computers.com IDE Board
                            	  1111: ;       Normally the DMA buffers will reside in the RAM on the 68K board itself at 00FD9000H 
                            	  1112: ;
                            	  1113: ;**********************************************************************************************************
                            	  1114:  
01:000907DA 45FA7D30        	  1115: MY_IDE:	LEA	DISPLAY_FLAG,A2	;Do we have detail sector data display flag on or off
01:000907DE 14B800FF        	  1116: 	MOVE.B	$FF,(A2)	;Set default to detailed sector display
                            	  1117: 	
                            	  1118: 	
01:000907E2 61000C98        	  1119: 	BSR	CLEAR_ID_BUFFER	;Clear ID Buffer
                            	  1120: 
01:000907E6 610000F4        	  1121: 	BSR	SEL_DRIVE_A	;Select the first Drive/CF card
01:000907EA 61000A20        	  1122: 	BSR	IDEinit	;Initialize the board and drive 0. If there is no drive abort
01:000907EE 670C            	  1123: 	BEQ	INIT1_OK
                            	  1124: 	
01:000907F0 45FA1B74        	  1125: 	LEA	INIT_1_ERROR,A2
01:000907F4 6100114C        	  1126: 	BSR	PRINT_STRING
01:000907F8 6000F85E        	  1127: 	BRA	LOOP
                            	  1128: 
                            	  1129: INIT1_OK:
01:000907FC 610000FA        	  1130: 	BSR	SEL_DRIVE_B	;Select the second Drive/CF card (Do not mess with CPM Drive 0)
01:00090800 61000A0A        	  1131: 	BSR	IDEinit	;Initialize drive 1. If there is no drive abort
01:00090804 670C            	  1132: 	BEQ	INIT2_OK
                            	  1133: 
01:00090806 61000C74        	  1134: 	BSR	CLEAR_ID_BUFFER	;Clear ID Buffer
                            	  1135: 	
01:0009080A 45FA1B95        	  1136: 	LEA	INIT_2_ERROR,A2	;Warn second IDE drive did not initilize
01:0009080E 61001132        	  1137: 	BSR	PRINT_STRING
                            	  1138: 
                            	  1139: INIT2_OK:
01:00090812 610000C8        	  1140: 	BSR	SEL_DRIVE_A	;Back to first drive/CF Card
                            	  1141: 
01:00090816 610000EE        	  1142: 	BSR	DRIVE_ID	;Get the drive 0 id info. If there is no drive just abort
01:0009081A 6708            	  1143: 	BEQ	INIT3_OK
                            	  1144: 	
01:0009081C 45FA1BC5        	  1145: 	LEA	BAD_DRIVE,A2
01:00090820 61001120        	  1146: 	BSR	PRINT_STRING
                            	  1147: ;	BRA	LOOP
                            	  1148: 
                            	  1149: INIT3_OK:			;Set default position will be first sector block 
01:00090824 45FA78E6        	  1150: 	LEA	IDE_BUFFER+12,A2	
01:00090828 4A52            	  1151: 	CMP.W	#0,(A2)	;Is it non zero
01:0009082A 6608            	  1152: 	BNE	INIT4_OK	;If there are zero sectors then something wrong
                            	  1153: 	
                            	  1154: 
01:0009082C 45FA1BB5        	  1155: 	LEA	BAD_DRIVE,A2	;"Error obtaining first Drive ID"
01:00090830 61001110        	  1156: 	BSR	PRINT_STRING
                            	  1157: ;	BRA	LOOP
                            	  1158: 	
01:00090834 42390009850D    	  1159: INIT4_OK:	CLR.B	(RAM_SEC)	;Sec 0
01:0009083A 13FC00000009850E	  1160: 	MOVE.B	#0,(RAM_TRK)	;Track 0
                            	  1161: 	
01:00090842 49FA78BC        	  1162: 	LEA	IDE_BUFFER,A4
01:00090846 23CC00098500    	  1163: 	MOVE.L	A4,(RAM_DMA)
                            	  1164: 
                            	  1165: ;	BSR	IDEinit	;For some reason this need to be here after getting the drive ID.
                            	  1166: 			;otherewise sector #'s are off by one! (Probably because on non-LBA reads)
01:0009084C 61000B3C        	  1167: 	BSR	WR_LBA	;Update LBA on "1st" drive
                            	  1168: 
                            	  1169: 
                            	  1170: 
                            	  1171: ;------------- MAIN IDE DRIVE DIAGNOSTIC MENU ---------------------------	
                            	  1172: 	
01:00090850 45FA18F6        	  1173: IDE_LOOP:	LEA	IDE_SIGNON0,A2	;List IDE command options
01:00090854 610010EC        	  1174: 	BSR	PRINT_STRING
                            	  1175: 
01:00090858 4A390009850F    	  1176: 	CMP.B	#0,(CURRENT_IDE_DRIVE)
01:0009085E 6606            	  1177: 	BNE	SIGN_B
01:00090860 45FA223A        	  1178: 	LEA	CURRENT_MSG_A,A2
01:00090864 6004            	  1179: 	BRA	IDE_LOOP0
01:00090866 45FA224D        	  1180: SIGN_B:	LEA	CURRENT_MSG_B,A2
                            	  1181: IDE_LOOP0:
01:0009086A 610010D6        	  1182: 	BSR	PRINT_STRING
                            	  1183: 	
01:0009086E 4A390009850C    	  1184: 	CMP.B	#0,(DISPLAY_FLAG)	;Do we have detail sector data display flag ON or OFF
01:00090874 6606            	  1185: 	BNE	IDE_LOOP1
01:00090876 45FA18F3        	  1186: 	LEA	IDE_SIGNON1,A2	;"ON"
01:0009087A 6004            	  1187: 	BRA	IDE_LOOP2
                            	  1188: IDE_LOOP1:
01:0009087C 45FA193E        	  1189: 	LEA	IDE_SIGNON2,A2	;"OFF"
                            	  1190: IDE_LOOP2:
01:00090880 610010C0        	  1191: 	BSR	PRINT_STRING
                            	  1192: 	
                            	  1193: 	
01:00090884 45FA1988        	  1194: 	LEA	IDE_SIGNON3,A2	;List IDE command options
01:00090888 610010B8        	  1195: 	BSR	PRINT_STRING
                            	  1196: 	
01:0009088C 61000732        	  1197: 	BSR	DISPLAY_POSITION	;Display current Track,sector,head#
                            	  1198: 
01:00090890 610010BE        	  1199: 	BSR	CRLF
01:00090894 45FA1A9B        	  1200: 	LEA	IDE_MENU_CMD,A2	;Enter a command 
01:00090898 610010A8        	  1201: 	BSR	PRINT_STRING
                            	  1202: 
01:0009089C 61000FF6        	  1203: 	BSR	GETCHAR	;Get a command from Console
01:000908A0 B23C001B        	  1204: 	CMP.B	#ESC,D1	;Abort if ESC
01:000908A4 6604            	  1205: 	BNE	NOT_ESC
01:000908A6 6000F784        	  1206: 	BRA	START	;Back to start of Monitor
                            	  1207: 
01:000908AA 610010CA        	  1208: NOT_ESC:	BSR	TOUPPER	;Lower case to Upper case
                            	  1209:    
                            	  1210:    IFNE SIMMULATOR		;If SIMMULATOR = 1
                            	  1211: 	BSR	PUTCHAR	;Echo character
                            	  1212:    ENDC	
01:000908AE B23C0041        	  1213:    	CMP.B	#'A',D1
01:000908B2 6D00F7D2        	  1214:    	BLT	ERR
01:000908B6 B23C005A        	  1215:    	CMP.B	#'Z',D1
01:000908BA 6E00F7CA        	  1216:    	BGT	ERR
01:000908BE 04010041        	  1217:    	SUBI.B	#'A',D1
01:000908C2 4881            	  1218:    	EXT.W   D1
01:000908C4 E589            	  1219:     	LSL.L	#2,D1	;X4 for offset into table
01:000908C6 45FA11F8        	  1220:   	LEA	IDE_TABLE,A2	;Start of cnd table
01:000908CA 26721000        	  1221:    	MOVE.L	(A2,D1),A3	;Add in X4 offset
01:000908CE 4ED3            	  1222:    	JMP	(A3)
                            	  1223: 
                            	  1224: ;             INDIVIDUAL IDE DRIVE MENU COMMANDS 
                            	  1225: 
                            	  1226: ;---------------Select Drive/CF card ------------------------------------------
                            	  1227: SET_DRIVE_A: 		;Select First Drive
01:000908D0 610A            	  1228:             BSR     SEL_DRIVE_A
01:000908D2 6000FF7C        	  1229:             BRA     IDE_LOOP	;Back to IDE Menu
                            	  1230: 
                            	  1231: SET_DRIVE_B: 		;Select First Drive
01:000908D6 6120            	  1232:             BSR     SEL_DRIVE_B
01:000908D8 6000FF76        	  1233:             BRA	IDE_LOOP	;Back to IDE Menu
                            	  1234: 
                            	  1235: SEL_DRIVE_A:		;Select First Drive
01:000908DC 45FA2251        	  1236: 	LEA	IDE_SEL_A,A2	;Say so
01:000908E0 61001060        	  1237: 	BSR	PRINT_STRING
01:000908E4 4201            	  1238: 	CLR.B	D1
                            	  1239: SELECT_DRIVE:
01:000908E6 13C10009850F    	  1240: 	MOVE.B	D1,CURRENT_IDE_DRIVE
01:000908EC 13C100FF0034    	  1241: 	MOVE.B	D1,IDEDrivePort	;Select Drive 0 or 1
01:000908F2 6100105C        	  1242: 	BSR	CRLF	
01:000908F6 4E75            	  1243: 	RTS
                            	  1244: 
                            	  1245: SEL_DRIVE_B:		;Select Drive 1
01:000908F8 45FA224F        	  1246: 	LEA	IDE_SEL_B,A2	;Say so
01:000908FC 61001044        	  1247: 	BSR	PRINT_STRING
01:00090900 123C0001        	  1248: 	MOVE.B	#1,D1
01:00090904 60E0            	  1249: 	JMP	SELECT_DRIVE
                            	  1250: 
                            	  1251: 
                            	  1252: ;---------------- Do the IDEntify drive command, and display the IDE_BUFFER ------------
                            	  1253: DRIVE_ID:
01:00090906 61000B28        	  1254: 	BSR	IDEwaitnotbusy
01:0009090A 6C06            	  1255: 	BGE	L_5
01:0009090C 4241            	  1256: 	CLR	D1
01:0009090E 5301            	  1257: 	SUBQ.B	#1,D1	;NZ if error
01:00090910 4E75            	  1258: 	RTS		;If Busy return NZ
                            	  1259: 	
01:00090912 183C00EC        	  1260: L_5:	MOVE.B	#COMMANDid,D4
01:00090916 1A3C000F        	  1261: 	MOVE.B	#REGcommand,D5
01:0009091A 61000BAA        	  1262: 	BSR	IDEwr8D	;Issue the command
                            	  1263: 	
01:0009091E 61000B36        	  1264: 	BSR	IDEwaitdrq	;Wait for Busy=0, DRQ=1
01:00090922 6C04            	  1265: 	BGE	L_6	
01:00090924 60000826        	  1266: 	BRA	SHOWerrors
                            	  1267: 	
01:00090928 4206            	  1268: L_6:	CLR.B	D6	;256 words
                            	  1269: 
01:0009092A 45FA77D4        	  1270: 	LEA	IDE_BUFFER,A2	;Store data here
01:0009092E 610009A2        	  1271: 	BSR	MoreRD16	;Get 256 words of data from REGdata port to IDE_BUFFER
                            	  1272: 
01:00090932 45FA1B13        	  1273: 	LEA	msgmdl,A2	;Print the drive's model number
01:00090936 6100100A        	  1274: 	BSR	PRINT_STRING
                            	  1275: 	
01:0009093A 45FA77FA        	  1276: 	LEA	IDE_BUFFER+54,A2
01:0009093E 163C0014        	  1277: 	MOVE.B	#20,D3	;Character count in words
01:00090942 6168            	  1278: 	BSR	Print_ID_Info	;Print [A2], [D3] X 2 characters
01:00090944 6100100A        	  1279: 	BSR	CRLF
                            	  1280: 			;print the drive's serial number
01:00090948 45FA1B24        	  1281: 	LEA	msgsn,A2
01:0009094C 61000FF4        	  1282: 	BSR	PRINT_STRING
01:00090950 45FA77C2        	  1283: 	LEA	IDE_BUFFER+20,A2
01:00090954 163C000A        	  1284: 	MOVE.B	#10,D3	;Character count in words
01:00090958 6152            	  1285: 	BSR	Print_ID_Info
01:0009095A 61000FF4        	  1286: 	BSR	CRLF
                            	  1287: 			;PRINT_STRING the drive's firmware revision string
01:0009095E 45FA1B16        	  1288: 	LEA	msgrev,A2
01:00090962 61000FDE        	  1289: 	BSR	PRINT_STRING
01:00090966 45FA77C6        	  1290: 	LEA	IDE_BUFFER+46,A2
01:0009096A 163C0004        	  1291: 	MOVE.B	#4,D3
01:0009096E 613C            	  1292: 	BSR	Print_ID_Info	;Character count in words
01:00090970 61000FDE        	  1293: 	BSR	CRLF
                            	  1294: 			;Print the drive's cylinder, head, and sector specs
01:00090974 45FA1B08        	  1295: 	LEA	msgcy,A2
01:00090978 61000FC8        	  1296: 	BSR	PRINT_STRING
01:0009097C 45FA7784        	  1297: 	LEA	IDE_BUFFER+2,A2
01:00090980 6140            	  1298: 	BSR	Print_ID_Hex
01:00090982 45FA1B06        	  1299: 	LEA	msghd,A2
01:00090986 61000FBA        	  1300: 	BSR	PRINT_STRING
01:0009098A 45FA777A        	  1301: 	LEA	IDE_BUFFER+6,A2
01:0009098E 6132            	  1302: 	BSR	Print_ID_Hex
01:00090990 45FA1B02        	  1303: 	LEA	msgsc,A2
01:00090994 61000FAC        	  1304: 	BSR	PRINT_STRING
01:00090998 45FA7772        	  1305: 	LEA	IDE_BUFFER+12,A2
01:0009099C 6124            	  1306: 	BSR	Print_ID_Hex
01:0009099E 61000FB0        	  1307: 	BSR	CRLF
01:000909A2 61000FAC        	  1308: 	BSR	CRLF	
01:000909A6 4203            	  1309: 	CLR.B	D3	;Ret Z
01:000909A8 6000FEA6        	  1310: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1311: 	
                            	  1312: Print_ID_Info:
01:000909AC 122A0001        	  1313: 	MOVE.B	1(A2),D1	;Text is stored high byte then low byte
01:000909B0 61000ED0        	  1314: 	BSR	PUTCHAR
01:000909B4 1212            	  1315: 	MOVE.B	(A2),D1
01:000909B6 61000ECA        	  1316: 	BSR	PUTCHAR
01:000909BA 548A            	  1317: 	ADDQ.L	#2,A2
01:000909BC 5303            	  1318: 	SUBQ.B	#1,D3
01:000909BE 66EC            	  1319: 	BNE	Print_ID_Info
01:000909C0 4E75            	  1320: 	RTS
                            	  1321: 
                            	  1322: 			; Print a 16 bit number in RAM located @ [A2] 
                            	  1323: Print_ID_Hex:
01:000909C2 528A            	  1324: 	ADDQ.L	#1,A2	;(Note Special Low Byte First. Used only for Drive ID)
01:000909C4 61000E60        	  1325: 	BSR	PUTBYTE_D6
01:000909C8 1C22            	  1326: 	MOVE.B	-(A2),D6
01:000909CA 61000E5A        	  1327: 	BSR	PUTBYTE_D6
01:000909CE 4E75            	  1328: 	RTS
                            	  1329: 	
                            	  1330: 	
                            	  1331: 	
                            	  1332: ;-------------- Read the current selected sector (based on LBA) to the IDE Buffer
                            	  1333: READ_SEC:
01:000909D0 49FA772E        	  1334: 	LEA	IDE_BUFFER,A4
01:000909D4 23CC00098500    	  1335: 	MOVE.L	A4,RAM_DMA	;DMA initially to IDE_BUFFER
                            	  1336: 
01:000909DA 610008B4        	  1337: 	BSR	READSECTOR
                            	  1338: 	
01:000909DE 6708            	  1339: 	BEQ	Main1B
01:000909E0 61000F6E        	  1340: 	BSR	CRLF	;Here if there was a problem
01:000909E4 6000FE6A        	  1341: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1342: 
01:000909E8 61000F66        	  1343: Main1B:	BSR	CRLF	
01:000909EC 45FA1B33        	  1344:             LEA	msgrd,A2	;Sector read OK
01:000909F0 61000F50        	  1345: 	BSR	PRINT_STRING
                            	  1346: 
01:000909F4 123A7B16        	  1347: 	MOVE.B	DISPLAY_FLAG,D1	;Do we have detail sector data display flag on or off
01:000909F8 8201            	  1348: 	OR.B	D1,D1	;NZ = on
01:000909FA 6608            	  1349: 	BNE	SHOW_SEC_RDATA
01:000909FC 61000F52        	  1350: 	BSR	CRLF	
01:00090A00 6000FE4E        	  1351: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1352: 
                            	  1353: SHOW_SEC_RDATA:	
01:00090A04 49FA76FA        	  1354: 	LEA	IDE_BUFFER,A4
01:00090A08 23CC00098500    	  1355: 	MOVE.L	A4,RAM_DMA	;DMA initially to IDE_BUFFER
01:00090A0E 6100064E        	  1356: 	BSR	DISPLAY_SEC
01:00090A12 45FA2051        	  1357: 	LEA	CR_To_Continue,A2 
01:00090A16 61000F2A        	  1358: 	BSR	PRINT_STRING
01:00090A1A 61000E78        	  1359: 	BSR	GETCHAR
01:00090A1E 61000F30        	  1360: 	BSR	CRLF	
01:00090A22 6000FE2C        	  1361: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1362: 
                            	  1363: ;----------------- Write the current selected sector (based on LBA) from the IDE Buffer
                            	  1364: WRITE_SEC:
01:00090A26 45FA1AB8        	  1365: 	LEA	CONFIRM_WR_MSG,A2	;Are you sure?
01:00090A2A 61000F16        	  1366: 	BSR	PRINT_STRING
01:00090A2E 61000E64        	  1367: 	BSR	GETCHAR
01:00090A32 61000F42        	  1368: 	BSR	TOUPPER
01:00090A36 B23C0059        	  1369: 	CMP.B	#'Y',D1
01:00090A3A 6708            	  1370: 	BEQ	WR_SEC_OK1
01:00090A3C 61000F12        	  1371: 	BSR	CRLF	;Here if there was a problem
01:00090A40 6000FE0E        	  1372: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1373:  
01:00090A44 61000F0A        	  1374: WR_SEC_OK1: BSR	CRLF
01:00090A48 49FA76B6        	  1375: 	LEA	IDE_BUFFER,A4
01:00090A4C 23CC00098500    	  1376: 	MOVE.L	A4,(RAM_DMA)	;DMA initially to IDE_BUFFER
                            	  1377: 
01:00090A52 610008BC        	  1378: 	BSR	WRITESECTOR	;Will write whatever is in the IDE_BUFFER
                            	  1379: 	
01:00090A56 6708            	  1380: 	BEQ	Main2B
01:00090A58 61000EF6        	  1381: 	BSR	CRLF	;Here if there was a problem
01:00090A5C 6000FDF2        	  1382: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1383: Main2B:	
01:00090A60 45FA1AD0        	  1384: 	LEA	msgwr,A2	;Sector written OK
01:00090A64 61000EDC        	  1385: 	BSR	PRINT_STRING
                            	  1386: 
01:00090A68 123A7AA2        	  1387: 	MOVE.B	(DISPLAY_FLAG),D1	;Do we have detail sector data display flag on or off
01:00090A6C 8201            	  1388: 	OR.B	D1,D1
01:00090A6E 6608            	  1389: 	BNE	SHOW_SEC_WDATA
01:00090A70 61000EDE        	  1390: 	BSR	CRLF	
01:00090A74 6000FDDA        	  1391: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1392: 
                            	  1393: SHOW_SEC_WDATA:	
01:00090A78 49FA7686        	  1394: 	LEA	IDE_BUFFER,A4
01:00090A7C 23CC00098500    	  1395: 	MOVE.L	A4,(RAM_DMA)	;DMA initially to IDE_BUFFER
01:00090A82 610005DA        	  1396: 	BSR	DISPLAY_SEC
01:00090A86 45FA1FDD        	  1397: 	LEA	CR_To_Continue,A2 
01:00090A8A 61000EB6        	  1398: 	BSR	PRINT_STRING
01:00090A8E 61000E04        	  1399: 	BSR	GETCHAR
01:00090A92 61000EBC        	  1400: 	BSR	CRLF	
01:00090A96 6000FDB8        	  1401: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1402: 	
                            	  1403: 
                            	  1404: ;---------------------  Set a new LBA value from inputted Track/Sec info. Send to drive
                            	  1405: SET_LBA:
01:00090A9A 45FA1AA8        	  1406: 	LEA	SET_LBA_MSG,A2	;Set new LBA and send to drive
01:00090A9E 61000EA2        	  1407: 	BSR	PRINT_STRING
01:00090AA2 610004DA        	  1408: 	BSR	GEN_HEX32_LBA	;Get new CPM style Track & Sector number and put them in RAM at RAM_SEC & RAM_TRK 
01:00090AA6 6D04            	  1409: 	BLT	main3b	;Ret C set if abort/error
01:00090AA8 610008E0        	  1410: 	BSR	WR_LBA	;Update LBA on drive
01:00090AAC 61000EA2        	  1411: main3b:	BSR	CRLF	
01:00090AB0 6000FD9E        	  1412: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1413: 
                            	  1414: 
                            	  1415: ;---------------------- Toggle detailed sector display on/off
                            	  1416: DISPLAY:
01:00090AB4 46390009850C    	  1417: 	NOT.B	(DISPLAY_FLAG)	;Do we have detail sector data display flag on or off
01:00090ABA 61000E94        	  1418: 	BSR	CRLF
01:00090ABE 6000FD90        	  1419: 	BRA	IDE_LOOP	;Update menu showing new "D" command
                            	  1420: 
                            	  1421: 
                            	  1422: ;--------------------- Point current sector to next sector
                            	  1423: NEXT_SECT:
01:00090AC2 61000618        	  1424: 	BSR	GET_NEXT_SECT
01:00090AC6 6608            	  1425: 	BNE	AT_END
01:00090AC8 61000E86        	  1426: 	BSR	CRLF	
01:00090ACC 6000FD82        	  1427: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1428: AT_END:
01:00090AD0 45FA1E82        	  1429: 	LEA	AT_END_MSG,A2	;Tell us we are at end of disk
01:00090AD4 61000E6C        	  1430: 	BSR	PRINT_STRING
01:00090AD8 61000E76        	  1431: 	BSR	CRLF	
01:00090ADC 6000FD72        	  1432: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1433: 
                            	  1434: ;--------------------- Point current sector to previous sector
                            	  1435: PREV_SECT:
01:00090AE0 6100062E        	  1436: 	BSR	GET_PREV_SECT
01:00090AE4 6608            	  1437: 	BNE	AT_START
01:00090AE6 61000E68        	  1438: 	BSR	CRLF	
01:00090AEA 6000FD64        	  1439: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1440: AT_START:
01:00090AEE 45FA1E47        	  1441: 	LEA	AT_START_MSG,A2	;Tell us we are at start of disk
01:00090AF2 61000E4E        	  1442: 	BSR	PRINT_STRING
01:00090AF6 61000E58        	  1443: 	BSR	CRLF	
01:00090AFA 6000FD54        	  1444: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1445: 	
                            	  1446: ;--------------------- Sequentially read sectors from disk starting at current LBA position
                            	  1447: SEQ_SEC_RD:
01:00090AFE 61000930        	  1448: 	BSR	IDEwaitnotbusy	
01:00090B02 6C04            	  1449: 	BGE	MORE_SEC	
01:00090B04 60000646        	  1450: 	BRA	SHOWerrors
                            	  1451: 
                            	  1452: MORE_SEC:
01:00090B08 61000E46        	  1453: 	BSR	CRLF
01:00090B0C 49FA75F2        	  1454: 	LEA	IDE_BUFFER,A4
01:00090B10 23CC00098500    	  1455: 	MOVE.L	A4,(RAM_DMA)	;DMA initially to IDE_BUFFER
                            	  1456: 
                            	  1457: 	
01:00090B16 123C003C        	  1458: 	MOVE.B	#'<',D1
01:00090B1A 61000D66        	  1459: 	BSR	PUTCHAR
01:00090B1E 2847            	  1460: 	MOVE.L	D7,A4
01:00090B20 61000CC4        	  1461: 	BSR	PUTLONG_D7
01:00090B24 123C003E        	  1462: 	MOVE.B	#'>',D1
01:00090B28 61000D58        	  1463: 	BSR	PUTCHAR
                            	  1464: 	
01:00090B2C 61000762        	  1465: 	BSR	READSECTOR	;If there are errors they will show up in READSECTOR
01:00090B30 671E            	  1466: 	BEQ	SEQOK
                            	  1467: 
01:00090B32 45FA1D61        	  1468: 	LEA	CONTINUE_MSG,A2	;If an error ask if we wish to continue
01:00090B36 61000E0A        	  1469: 	BSR	PRINT_STRING
01:00090B3A 61000D58        	  1470: 	BSR	GETCHAR
01:00090B3E 61000E36        	  1471: 	BSR	TOUPPER
01:00090B42 B23C001B        	  1472: 	CMP.B	#ESC,D1	;Abort if ESC
01:00090B46 6608            	  1473: 	BNE	SEQOK
01:00090B48 61000E06        	  1474: 	BSR	CRLF	
01:00090B4C 6000FD02        	  1475: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1476: 
01:00090B50 6100046E        	  1477: SEQOK:	BSR	DISPLAY_POSITION	;Display current Track,sector,head#
                            	  1478: 	
01:00090B54 4A390009850C    	  1479: 	CMP.B	#0,(DISPLAY_FLAG)	;Do we have detail sector data display flag on or off
01:00090B5A 670E            	  1480: 	BEQ	MORES2	;NZ = on
01:00090B5C 49FA75A2        	  1481: 	LEA	IDE_BUFFER,A4
01:00090B60 23CC00098500    	  1482: 	MOVE.L	A4,(RAM_DMA)	;DMA initially to IDE_BUFFER
                            	  1483: 
01:00090B66 610004F6        	  1484: 	BSR	DISPLAY_SEC
                            	  1485: 
01:00090B6A 61000D3C        	  1486: MORES2:	BSR	GETSTAT	;Any keyboard character will stop display
01:00090B6E 6722            	  1487: 	BEQ	NO_WAIT			
01:00090B70 61000D22        	  1488: 	BSR	GETCHAR			
01:00090B74 45FA1D1F        	  1489: 	LEA	CONTINUE_MSG,A2
01:00090B78 61000DC8        	  1490: 	BSR	PRINT_STRING
01:00090B7C 61000D16        	  1491: 	BSR	GETCHAR
01:00090B80 61000DF4        	  1492: 	BSR	TOUPPER
01:00090B84 B23C001B        	  1493: 	CMP.B	#ESC,D1
01:00090B88 6608            	  1494: 	BNE	NO_WAIT
01:00090B8A 61000DC4        	  1495: 	BSR	CRLF	
01:00090B8E 6000FCC0        	  1496: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1497: 
                            	  1498: NO_WAIT:
01:00090B92 61000548        	  1499: 	BSR	GET_NEXT_SECT	;Point LBA to next sector
01:00090B96 6700FF70        	  1500: 	BEQ	MORE_SEC	;Note will go to last sec on disk unless stopped
01:00090B9A 61000DB4        	  1501: 	BSR	CRLF	
01:00090B9E 6000FCB0        	  1502: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1503: 
                            	  1504: 
                            	  1505: 
                            	  1506: 
                            	  1507: 
                            	  1508: ;--------------- Read N Sectors to disk
                            	  1509: ;Note unlike the normal sector read, this routine increments the DMA address after each sector read
                            	  1510:  
                            	  1511: N_RD_SEC:			
01:00090BA2 45FA1DEC        	  1512: 	LEA	READN_MSG,A2
01:00090BA6 61000D9A        	  1513: 	BSR	PRINT_STRING
01:00090BAA 61000B9C        	  1514: 	BSR	GETLONG_D7	;Hex to D7
                            	  1515: 	
01:00090BAE 33C700098506    	  1516: 	MOVE.W	D7,(SECTOR_COUNT)	;Store sector count
                            	  1517: 
01:00090BB4 49FA754A        	  1518: 	LEA	IDE_BUFFER,A4
01:00090BB8 23CC00098502    	  1519: 	MOVE.L	A4,(RAM_DMA_STORE)	;DMA initially to IDE_BUFFER
                            	  1520: 
                            	  1521: NextRSec:	
01:00090BBE 45FA1DD0        	  1522: 	LEA	READN_MSG,A2
01:00090BC2 61000D7E        	  1523: 	BSR	PRINT_STRING
01:00090BC6 610007C2        	  1524: 	BSR	WR_LBA	;Update LBA on drive
01:00090BCA 610003F4        	  1525: 	BSR	DISPLAY_POSITION	;Display current Track,sector,head#
                            	  1526: 	
01:00090BCE 223A7932        	  1527: 	MOVE.L	(RAM_DMA_STORE),D1	;DMA initially to IDE_BUFFER
01:00090BD2 23C100098500    	  1528: 	MOVE.L	D1,(RAM_DMA)
                            	  1529: 
01:00090BD8 610006B6        	  1530: 	BSR	READSECTOR	;Actully, Sector/track values are already updated
                            	  1531: 
01:00090BDC 223A7922        	  1532: 	MOVE.L	(RAM_DMA),D1
01:00090BE0 23C100098502    	  1533: 	MOVE.L	D1,(RAM_DMA_STORE)
                            	  1534: 
01:00090BE6 537900098506    	  1535: 	SUBQ.W	#1,(SECTOR_COUNT)
01:00090BEC 6608            	  1536: 	BNE	NEXT_SEC_NRD
01:00090BEE 61000D60        	  1537: 	BSR	CRLF	
01:00090BF2 6000FC5C        	  1538: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1539: 	
                            	  1540: NEXT_SEC_NRD:
01:00090BF6 610004E4        	  1541: 	BSR	GET_NEXT_SECT		
01:00090BFA 67C2            	  1542: 	BEQ	NextRSec
01:00090BFC 45FA1D56        	  1543: 	LEA	AT_END_MSG,A2	;Tell us we are at end of disk
01:00090C00 61000D40        	  1544: 	BSR	PRINT_STRING
01:00090C04 61000D4A        	  1545: 	BSR	CRLF	
01:00090C08 6000FC46        	  1546: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1547: 
                            	  1548: 
                            	  1549: 
                            	  1550: ;------------------ Write N Sectors to disk
                            	  1551: ;Note unlike the normal sector write routine, this routine incriments the DMA address after each write.
                            	  1552: 
                            	  1553: N_WR_SEC:			
01:00090C0C 45FA18D2        	  1554: 	LEA	CONFIRM_WR_MSG,A2	;Are you sure?
01:00090C10 61000D30        	  1555: 	BSR	PRINT_STRING
01:00090C14 61000C7E        	  1556: 	BSR	GETCHAR
01:00090C18 61000D5C        	  1557: 	BSR	TOUPPER
01:00090C1C B23C0059        	  1558: 	CMP.B	#'Y',D1
01:00090C20 6708            	  1559: 	BEQ	WR_SEC_OK2
01:00090C22 61000D2C        	  1560: 	BSR	CRLF	;Here if there was a problem
01:00090C26 6000FC28        	  1561: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1562:  
                            	  1563: WR_SEC_OK2:
01:00090C2A 45FA1D80        	  1564: 	LEA	WRITEN_MSG,A2
01:00090C2E 61000D12        	  1565: 	BSR	PRINT_STRING
01:00090C32 61000B14        	  1566: 	BSR	GETLONG_D7	;Hex to D7
                            	  1567: 	
01:00090C36 33C700098506    	  1568: 	MOVE.W	D7,(SECTOR_COUNT)	;store sector count
                            	  1569: 
01:00090C3C 49FA74C2        	  1570: 	LEA	IDE_BUFFER,A4
01:00090C40 23CC00098502    	  1571: 	MOVE.L	A4,(RAM_DMA_STORE)	;DMA initially to IDE_BUFFER
                            	  1572: 
                            	  1573: NextWSec:	
01:00090C46 45FA1D64        	  1574: 	LEA	WRITEN_MSG,A2
01:00090C4A 61000CF6        	  1575: 	BSR	PRINT_STRING
01:00090C4E 6100073A        	  1576: 	BSR	WR_LBA	;Update LBA on drive
01:00090C52 6100036C        	  1577: 	BSR	DISPLAY_POSITION	;Display current Track,sector,head#
                            	  1578: 	
01:00090C56 223A78AA        	  1579: 	MOVE.L	(RAM_DMA_STORE),D1	;DMA initially to IDE_BUFFER
01:00090C5A 23C100098500    	  1580: 	MOVE.L	D1,(RAM_DMA)
                            	  1581: 
01:00090C60 610006AE        	  1582: 	BSR	WRITESECTOR	;Actully, Sector/track values are already updated
                            	  1583: 
01:00090C64 223A789A        	  1584: 	MOVE.L	(RAM_DMA),D1
01:00090C68 23C100098502    	  1585: 	MOVE.L	D1,(RAM_DMA_STORE)
                            	  1586: 
01:00090C6E 537900098506    	  1587: 	SUBQ.W	#1,(SECTOR_COUNT)
01:00090C74 6608            	  1588: 	BNE	NEXT_SEC_NWR
01:00090C76 61000CD8        	  1589: 	BSR	CRLF	
01:00090C7A 6000FBD4        	  1590: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1591: 
                            	  1592: NEXT_SEC_NWR:
01:00090C7E 6100045C        	  1593: 	BSR	GET_NEXT_SECT		
01:00090C82 67C2            	  1594: 	BEQ	NextWSec
01:00090C84 45FA1CCE        	  1595: 	LEA	AT_END_MSG,A2	;Tell us we are at end of disk
01:00090C88 61000CB8        	  1596: 	BSR	PRINT_STRING
01:00090C8C 61000CC2        	  1597: 	BSR	CRLF	
01:00090C90 6000FBBE        	  1598: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1599: 
                            	  1600: ;-------------- Format current disk
                            	  1601: FORMAT:	
01:00090C94 4A390009850F    	  1602: 	CMP.B	#0,(CURRENT_IDE_DRIVE)
01:00090C9A 6606            	  1603: 	BNE	FORM_B
01:00090C9C 45FA1C29        	  1604: 	LEA	FORMAT_MSG_A,A2
01:00090CA0 6004            	  1605: 	BRA	FORM_X
01:00090CA2 45FA1C4B        	  1606: FORM_B:	LEA	FORMAT_MSG_B,A2
01:00090CA6 61000C9A        	  1607: FORM_X: BSR	PRINT_STRING
01:00090CAA 45FA1834        	  1608: 	LEA	CONFIRM_WR_MSG,A2	;Are you sure?
01:00090CAE 61000C92        	  1609: 	BSR	PRINT_STRING
01:00090CB2 61000BE0        	  1610: 	BSR	GETCHAR
01:00090CB6 61000CBE        	  1611: 	BSR	TOUPPER
01:00090CBA B23C0059        	  1612: 	CMP.B	#'Y',D1
01:00090CBE 6708            	  1613: 	BEQ	FORMAT_OK	
01:00090CC0 61000C8E        	  1614: 	BSR	CRLF	
01:00090CC4 6000FB8A        	  1615: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1616: 	
                            	  1617: FORMAT_OK:
01:00090CC8 13FC00000009850D	  1618: 	MOVE.B	#0,(RAM_SEC)	;Back to CPM sector 0
01:00090CD0 13FC00000009850E	  1619: 	MOVE.B	#0,(RAM_TRK)
                            	  1620: 
01:00090CD8 323CE5E5        	  1621: 	MOVE.W	#$0E5E5,D1	;First set Sector pattern to E5's
01:00090CDC 6100024E        	  1622: 	BSR	RAM_FILL
01:00090CE0 61000C6E        	  1623: 	BSR	CRLF
                            	  1624: 
                            	  1625: NEXT_FORMAT:
01:00090CE4 287A741A        	  1626: 	MOVE.L	IDE_BUFFER,A4
01:00090CE8 23CC00098500    	  1627: 	MOVE.L	A4,(RAM_DMA)
                            	  1628: 
01:00090CEE 61000620        	  1629: 	BSR	WRITESECTOR	;Will return error if there was one
01:00090CF2 6712            	  1630: 	BEQ	NEXTF1	;Z means the sector write was OK
                            	  1631: 	
01:00090CF4 45FA1DD8        	  1632: 	LEA	FORMAT_ERR,A2	;Indicate an error
01:00090CF8 61000C48        	  1633: 	BSR	PRINT_STRING
01:00090CFC 6100031C        	  1634: 	BSR	SHOW_TRACK_SEC	;Show current location of error
01:00090D00 61000C4E        	  1635: 	BSR	CRLF
01:00090D04 6016            	  1636: 	BRA	FNEXTSEC3
                            	  1637: 
01:00090D06 4A390009850D    	  1638: NEXTF1:	CMP.B	#0,(RAM_SEC)	;Get Current Sector
01:00090D0C 6604            	  1639: 	BNE	FNEXTSEC2
                            	  1640: 	
01:00090D0E 61000334        	  1641: 	BSR	SHOW_TRACK
                            	  1642: 
                            	  1643: FNEXTSEC2:
01:00090D12 61000B94        	  1644: 	BSR	GETSTAT	;Any keyboard character will stop display
01:00090D16 672C            	  1645: 	BEQ	FNEXTSEC1
01:00090D18 61000B7A        	  1646: 	BSR	GETCHAR	;Flush character
                            	  1647: FNEXTSEC3:	
01:00090D1C 45FA1B77        	  1648: 	LEA	CONTINUE_MSG,A2
01:00090D20 61000C20        	  1649: 	BSR	PRINT_STRING
01:00090D24 61000B6E        	  1650: 	BSR	GETCHAR
01:00090D28 B23C001B        	  1651: 	CMP.B	#ESC,D1
01:00090D2C 6616            	  1652: 	BNE	FNEXTSEC1
01:00090D2E 123C0000        	  1653: F_DONE:	MOVE.B	#0,D1	;Login drive A:
01:00090D32 6100FBB2        	  1654: 	BSR	SELECT_DRIVE
01:00090D36 13C10009850F    	  1655: 	MOVE.B	D1,(CURRENT_IDE_DRIVE)
01:00090D3C 61000C12        	  1656: 	BSR	CRLF	
01:00090D40 6000FB0E        	  1657: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1658: 
