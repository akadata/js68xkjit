                            	   328: SHOW_MENU:			;Display this monitors commands on CRT
01:000900A6 45FA1AD5        	   329: 	LEA	Menu,A2	;Menu string
01:000900AA 61001896        	   330: 	BSR	PRINT_STRING
01:000900AE 60A8            	   331: 	BRA	LOOP	;Back to start for next command
                            	   332: 	
