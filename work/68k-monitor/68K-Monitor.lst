01:00091B2D EA              	  3141: 		dc.b    $EA		;Enable, Transmit 8 bits
01:00091B2E 0B              	  3142: 		dc.b    $0B  		;Set RTS,DTR, Enable. Point to WR11
01:00091B2F 56              	  3143: 		dc.b    $56		;Recieve/transmit clock = BRG
01:00091B30 0C              	  3144: 		dc.b    $0C 		;Point to WR12
                            	  3145: ;		dc.b    $40		;Low Byte 2400 Baud 
                            	  3146: ;		dc.b    $1E		;Low Byte 4800 Baud 
                            	  3147: ;		dc.b    $0E		;Low Byte 9600 Baud 
                            	  3148: ;		dc.b    $06		;Low byte 19,200 Baud 
01:00091B31 02              	  3149: 		dc.b    $02		;Low byte 38,400 Baud <<<<<<<<<<< XModem I/O
                            	  3150: ;		dc.b    $00		;Low byte 76,800 Baud  
01:00091B32 0D              	  3151: 		dc.b    $0D		;Point to WR13
01:00091B33 00              	  3152: 		dc.b    $00		;High byte for Baud
01:00091B34 0E              	  3153: 		dc.b    $0E		;Point to WR14
01:00091B35 01              	  3154: 		dc.b    $01		;Use 4.9152 MHz Clock. Note SD Systems uses a 2.4576 MHz clock, enable BRG
01:00091B36 0F              	  3155: 		dc.b    $0F		;Point to WR15
01:00091B37 00              	  3156: 		dc.b    $00		;Generate Int with CTS going high
                            	  3157: 
