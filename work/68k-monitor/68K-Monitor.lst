                            	  1012: 	
01:00090700 14BC0000        	  1013: 	MOVE.B	#00,(A2)	;Currently will use TMA line #1 to switch in/out the 68K board 
01:00090704 4E71            	  1014: 	NOP		;<-- 68K Is held in HALT mode here until released again by the Z80/master CPU
01:00090706 4E71            	  1015: 	NOP
01:00090708 4E71            	  1016: 	NOP
01:0009070A 4E71            	  1017: 	NOP
