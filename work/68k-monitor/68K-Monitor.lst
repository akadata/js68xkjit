01:00090D76 13FC00000009850E	  1678: 	MOVE.B	#0,(RAM_TRK)	;Start with CPM Track 0
01:00090D7E 61000BD0        	  1679: 	BSR	CRLF
01:00090D82 61000BCC        	  1680: 	BSR	CRLF
                            	  1681: 	
                            	  1682: NextDCopy:	
