                            	  2603: 	
                            	  2604: 			;NEXT VERIFY CHECKSUM
01:000916A4 243C00001F40    	  2605: 	MOVE.L	#SERIAL_RETRYS,D2	;Number of times to try reading serial port before aborting.
01:000916AA 6100023C        	  2606: 	BSR	RECV	;GET CHECKSUM
01:000916AE B43C00FF        	  2607: 	CMP.B	#$FF,D2	;Return with FF in D2 if all is OK
01:000916B2 6600FF1A        	  2608: 	BNE	RECV_HDR_TIMEOUT
                            	  2609: MODL_5:
