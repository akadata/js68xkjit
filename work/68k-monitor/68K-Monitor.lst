01:00090DA4 6100FB40        	  1694: 	BSR	SELECT_DRIVE
                            	  1695: 	
01:00090DA8 610005E0        	  1696: 	BSR	WR_LBA	;Update LBA on "B:" drive
                            	  1697: 	
01:00090DAC 49FA7352        	  1698: 	LEA	IDE_BUFFER,A4
01:00090DB0 23CC00098500    	  1699: 	MOVE.L	A4,(RAM_DMA)
                            	  1700: 
01:00090DB6 61000558        	  1701: 	BSR	WRITESECTOR	;Write buffer data to sector on B: drive
