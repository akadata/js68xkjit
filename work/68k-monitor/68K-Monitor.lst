                            	  1021: SIGNALS:			;Setup hardware signal tests to look at S-100 signals pDBIN, pWR*
01:00090710 45FA1881        	  1022: 	LEA	SIGNALS_MSG,A2	;Put CPU in hardware loop to test (pDBIN or pWR*), Enter test RAM Location: 
01:00090714 6100122C        	  1023: 	BSR	PRINT_STRING
                            	  1024: 
01:00090718 6100102E        	  1025: 	BSR	GETLONG_D7	;Get RAM location 
01:0009071C 4A03            	  1026: 	TST.B	D3	;Byte count > 0
01:0009071E 6700F938        	  1027: 	BEQ	LOOP
01:00090722 B43C001B        	  1028: 	CMP.B	#ESC,D2	;If ESC then we abort
01:00090726 6700F930        	  1029: 	BEQ	LOOP
01:0009072A B43C000D        	  1030: 	CMP.B	#CR,D2	;If not CR then we also abort
01:0009072E 66001258        	  1031: 	BNE	ERROR
01:00090732 2647            	  1032: 	MOVE.L	D7,A3	;Store in A3 (also in D7)
                            	  1033: 
01:00090734 45FA18AB        	  1034: 	LEA	Menu_1or2_MSG,A2	;Enter 1=pDBIN, 2=pWR* : 
01:00090738 61001208        	  1035: 	BSR	PRINT_STRING
                            	  1036: 
01:0009073C 7200            	  1037: 	CLR.L	D1	;Just to be on the safe side
01:0009073E 61001154        	  1038: 	BSR	GETCHAR	;get a menu character
01:00090742 61001232        	  1039: 	BSR	TOUPPER	;Lower case to Upper case
                            	  1040: 
01:00090746 B23C0031        	  1041:  	CMP.B	#'1',D1	;Is it a pDBIN request
01:0009074A 670A            	  1042: 	BEQ	DBIN_TEST
01:0009074C B23C0032        	  1043: 	CMP.B	#'2',D1	;Is it a pWR* request
01:00090750 6732            	  1044: 	BEQ	WR_TEST
01:00090752 60001234        	  1045: 	BRA	ERROR	;Must be an error
                            	  1046: 
                            	  1047: 
                            	  1048: 
01:00090756 123C000D        	  1049: DBIN_TEST:	MOVE.B	#CR,D1	;Read test pDBIN
01:0009075A 61001126        	  1050: 	BSR	PUTCHAR
01:0009075E 123C000A        	  1051: 	MOVE.B	#LF,D1
01:00090762 6100111E        	  1052: 	BSR	PUTCHAR
01:00090766 123C0072        	  1053: 	MOVE.B	#'r',D1
01:0009076A 61001116        	  1054: 	BSR	PUTCHAR
                            	  1055: 	
01:0009076E 3413            	  1056: DBIN_TEST1:	MOVE.W	(A3),D2
01:00090770 3413            	  1057: 	MOVE.W	(A3),D2
01:00090772 3413            	  1058: 	MOVE.W	(A3),D2
01:00090774 3413            	  1059: 	MOVE.W	(A3),D2
01:00090776 3413            	  1060: 	MOVE.W	(A3),D2
01:00090778 3413            	  1061: 	MOVE.W	(A3),D2
01:0009077A 3413            	  1062: 	MOVE.W	(A3),D2
01:0009077C 3413            	  1063: 	MOVE.W	(A3),D2
01:0009077E 3413            	  1064: 	MOVE.W	(A3),D2
01:00090780 3413            	  1065: 	MOVE.W	(A3),D2
01:00090782 60EA            	  1066: 	BRA	DBIN_TEST1	;Must Hit Reset button to abort
                            	  1067: 	
                            	  1068: 	
01:00090784 343CAAAA        	  1069: WR_TEST:	MOVE.W	#$AAAA,D2	;Write test pWR*
01:00090788 1238000D        	  1070: 	MOVE.B	CR,D1
01:0009078C 610010F4        	  1071: 	BSR	PUTCHAR
01:00090790 123C000A        	  1072: 	MOVE.B	#LF,D1
01:00090794 610010EC        	  1073: 	BSR	PUTCHAR
01:00090798 123C0077        	  1074: 	MOVE.B	#'w',D1
01:0009079C 610010E4        	  1075: 	BSR	PUTCHAR
                            	  1076: 
01:000907A0 3682            	  1077: WR_TEST1:	MOVE.W	D2,(A3)
01:000907A2 3682            	  1078: 	MOVE.W	D2,(A3)
01:000907A4 3682            	  1079: 	MOVE.W	D2,(A3)
01:000907A6 3682            	  1080: 	MOVE.W	D2,(A3)
01:000907A8 3682            	  1081: 	MOVE.W	D2,(A3)
01:000907AA 3681            	  1082: 	MOVE.W	D1,(A3)
01:000907AC 3682            	  1083: 	MOVE.W	D2,(A3)
01:000907AE 3682            	  1084: 	MOVE.W	D2,(A3)
01:000907B0 3682            	  1085: 	MOVE.W	D2,(A3)
01:000907B2 3682            	  1086: 	MOVE.W	D2,(A3)
01:000907B4 60EA            	  1087: 	BRA	WR_TEST1	;Must Hit Reset button to abort
