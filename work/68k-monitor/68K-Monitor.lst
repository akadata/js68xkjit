01:00091B38 04              	  3159: 		dc.b    $04		;Point to WR4
01:00091B39 44              	  3160: 		dc.b    $44		;X16 clock,1 Stop,NP
01:00091B3A 03              	  3161: 		dc.b    $03		;Point to WR3
01:00091B3B C1              	  3162: 		dc.b    $C1		;Enable reciever, Auto Enable, Recieve 8 bits	
01:00091B3C 05              	  3163: 		dc.b    $05		;Point to WR5
01:00091B3D EA              	  3164: 		dc.b    $EA		;Enable, Transmit 8 bits
01:00091B3E 0B              	  3165: 		dc.b    $0B		;Set RTS,DTR, Enable. Point to WR11
01:00091B3F 56              	  3166: 		dc.b    $56		;Recieve/transmit clock = BRG
01:00091B40 0C              	  3167: 		dc.b    $0C		;Point to WR12
01:00091B41 06              	  3168: 		dc.b    $06		;Low byte 19,200 Baud <<<<<<<<<<< Note Speech synthizer defaults to this value
01:00091B42 0D              	  3169: 		dc.b    $0D		;Point to WR13
01:00091B43 00              	  3170: 		dc.b    $00		;High byte for Baud
01:00091B44 0E              	  3171: 		dc.b    $0E		;Point to WR14
