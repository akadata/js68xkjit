                            	  2880: ;--------------------------------- SERIAL PORT OUTPUT CHARACTER ROUTINE -----------------------------
                            	  2881: 
01:000918B2 2F05            	  2882: SERIAL_OUT:	MOVE.L	D5,-(A7)	;> Save D5
01:000918B4 2F02            	  2883: 	MOVE.L	D2,-(A7)	;> Save D2
01:000918B6 2F08            	  2884: 	MOVE.L	A0,-(A7)	;> Save A0
01:000918B8 207C00FF00A1    	  2885: 	MOVE.L	#ACTL,A0	;Point to Control port of Zilog serial chip
01:000918BE 343C0200        	  2886: 	MOVE.W  #512,D2	;Will check status 512 times (only)
                            	  2887: 	
                            	  2888: SERIAL_OUT_STAT:	
01:000918C2 1A10            	  2889: 	MOVE.B	(A0),D5	;Check serial port is ready
01:000918C4 02050004        	  2890: 	ANDI.B	#$04,D5
01:000918C8 4A05            	  2891: 	TST.B	D5
01:000918CA 6612            	  2892: 	BNE	SEND_SERIAL	;Ready to send	
01:000918CC 5342            	  2893: 	SUB.W	#1,D2	;Decraeae loop count
01:000918CE 4A42            	  2894: 	TST.W	D2
01:000918D0 66F0            	  2895: 	BNE	SERIAL_OUT_STAT
01:000918D2 123C0000        	  2896: 	MOVE.B	#0,D1	;Return empty just in case
                            	  2897: SERIAL_DONE:
01:000918D6 205F            	  2898: 	MOVE.L	(A7)+,A0	;< Restore A0
01:000918D8 241F            	  2899: 	MOVE.L	(A7)+,D2	;< Restore D2
01:000918DA 2A1F            	  2900: 	MOVE.L	(A7)+,D5	;< Restore D5
01:000918DC 4E75            	  2901: 	RTS		;Return from subroutine, char in D1
                            	  2902: 
                            	  2903: SEND_SERIAL:	
01:000918DE 207C00FF00A3    	  2904: 	MOVE.L	#ADTA,A0	;Point to data port of Zilog serial chip
01:000918E4 1081            	  2905: 	MOVE.B	D1,(A0)	
01:000918E6 60EE            	  2906: 	BRA	SERIAL_DONE
                            	  2907: 
                            	  2908: 
                            	  2909: ;--------------------------------- SERIAL PORT INPUT CHARACTER ROUTINE -----------------------------
                            	  2910: 			;For XMODEM input
01:000918E8 2F0B            	  2911: RECV:	MOVE.L	A3,-(A7)	;> Save A3
01:000918EA 6112            	  2912: 	BSR	SERIAL_IN_CORE	;D2 will contain delay countdown
01:000918EC 265F            	  2913: 	MOVE.L	(A7)+,A3	;< Restore A3
01:000918EE 4E75            	  2914: 	RTS
                            	  2915: 			;For other serial input
01:000918F0 2F0B            	  2916: SERIAL_IN:	MOVE.L	A3,-(A7)	;> Save A3
01:000918F2 243C00001F40    	  2917: 	MOVE.L	#SERIAL_RETRYS,D2	;Default number of times to try port before aborting
01:000918F8 6104            	  2918: 	BSR	SERIAL_IN_CORE	
01:000918FA 265F            	  2919: 	MOVE.L	(A7)+,A3	;< Restore A3
01:000918FC 4E75            	  2920: 	RTS
                            	  2921: 
                            	  2922: SERIAL_IN_CORE:
01:000918FE 267C00FF00A1    	  2923: 	MOVE.L	#ACTL,A3	;Point to Control port of Zilog serial chip
01:00091904 323C0005        	  2924: 	MOVE.W	#$5,D1
01:00091908 1681            	  2925: 	MOVE.B	D1,(A3)	;Lower RTS line
01:0009190A 323C00EA        	  2926: 	MOVE.W 	#$EA,D1
01:0009190E 1681            	  2927: 	MOVE.B	D1,(A3)	
01:00091910 4E71            	  2928: 	nop
01:00091912 4E71            	  2929: 	nop
01:00091914 4E71            	  2930: 	nop
01:00091916 4E71            	  2931: 	nop
01:00091918 1213            	  2932: SERIAL_IN2:	MOVE.B	(A3),D1
01:0009191A 02010001        	  2933: 	ANDI.B	#$01,D1
01:0009191E B23C0001        	  2934: 	CMP.B	#$01,D1
01:00091922 6710            	  2935: 	BEQ	SERIAL_IN3	;Get serial data
01:00091924 5382            	  2936: 	SUB.L	#1,D2
01:00091926 4A42            	  2937: 	TST.W	D2
01:00091928 66EE            	  2938: 	BNE	SERIAL_IN2
01:0009192A 143C0000        	  2939: 	MOVE.B	#0,D2	;Return with 0 in D2 if timeout
01:0009192E 123C0000        	  2940: 	MOVE.B	#0,D1	;Return with 0 in D1 if timeout
01:00091932 4E75            	  2941: 	RTS
                            	  2942: 	
01:00091934 267C00FF00A3    	  2943: SERIAL_IN3:	MOVE.L	#ADTA,A3	;Point to data port of Zilog serial chip
01:0009193A 1213            	  2944: 	MOVE.B	(A3),D1	;Get byte of data, put in D1
01:0009193C 143C00FF        	  2945: 	MOVE.B	#$FF,D2	;Return with FF in D2 if all is OK
01:00091940 4E75            	  2946: 	RTS	
