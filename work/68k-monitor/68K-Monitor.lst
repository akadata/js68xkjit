01:0009040C 6C06            	   702: 	BGE	VERIFY_OK
01:0009040E 2A4B            	   703: 	MOVE.L	A3,A5	;Else swap values
01:00090410 264C            	   704: 	MOVE.L	A4,A3
01:00090412 384D            	   705: 	MOVE	A5,A4
                            	   706: 
01:00090414 528C            	   707: VERIFY_OK:	ADD.L	#1,A4	;End + 1	
