                            	  2146: ;================================================================================================
                            	  2147: ; IDE Drive BIOS Routines written in a format that can be used with CPM68K throughout we 
                            	  2148: ; will use IDE_BUFFER so the the buffers can reside at the top segment of available RAM. 
                            	  2149: ; Normally this will be FD8100H  (Above the ROM).
                            	  2150: ;================================================================================================
                            	  2151: 
                            	  2152: IDEinit:					;Initilze the 8255 and drive then do a hard reset on the drive, 
                            	  2153: 					;By default the drive will come up initilized in LBA mode.
                            	  2154: 
01:0009120C 13FC009200FF0033	  2155: 	MOVE.B	#READcfg8255,IDECtrlPort	;Config 8255 chip, READ mode
                            	  2156: 
01:00091214 13FC000000FF0032	  2157:             MOVE.B  #0,IDEportC                 ;No IDE control lines asserted
01:0009121C 323C0020        	  2158:             MOVE.W  #$20,D1                     ;time delay for reset/initilization
01:00091220 5341            	  2159: InitDelay:  SUBQ.W  #1,D1
01:00091222 66FC            	  2160:             BNE     InitDelay                   ;Delay
                            	  2161: 
01:00091224 13FC008000FF0032	  2162: 	MOVE.B	#IDErstline,IDEportC     	;Hard reset the disk drive
                            	  2163: 	
01:0009122C 323C0020        	  2164: 	MOVE.W	#IDE_Reset_Delay,D1		;Time delay for reset/initilization (~66 uS, with 8MHz 8086, 1 I/O wait state)
                            	  2165: ResetDelay:
01:00091230 5341            	  2166: 	SUBQ.W	#1,D1
01:00091232 66FC            	  2167: 	BNE	ResetDelay		;Delay (IDE reset pulse width)
                            	  2168: 
01:00091234 13FC000000FF0032	  2169: 	MOVE.B	#0,IDEportC		;No IDE control lines asserted
                            	  2170: 
01:0009123C 6140            	  2171: 	BSR	DELAY_32		;Allow time for CF/Drive to recover
                            	  2172: 	
01:0009123E 183C00E0        	  2173: 	MOVE.B	#%11100000,D4		;Data for IDE SDH reg (512bytes, LBA mode,single drive,head 0000)
                            	  2174: ;	MOVE.B	#%10100000,D4		;For Trk,Sec,head (non LBA) use 10100000 (This is the mode we use for MSDOS)
                            	  2175: 					;Note. Cannot get LBA mode to work with an old Seagate Medalist 6531 drive.
                            	  2176: 					;have to use the non-LBA mode. (Common for old hard disks).
01:00091242 1A3C000E        	  2177: 	MOVE.B	#REGshd,D5		;00001110,(0EH) for CS0,A2,A1,  
01:00091246 6100027E        	  2178: 	BSR	IDEwr8D			;Write byte to select the MASTER device
                            	  2179: 
01:0009124A 1C3C00FF        	  2180: 	MOVE.B	#$FF,D6		;<<< May need to adjust delay time
                            	  2181: WaitInit:
01:0009124E 1A3C000F        	  2182: 	MOVE.B	#REGstatus,D5		;Get status after initilization
01:00091252 6100024E        	  2183: 	BSR	IDErd8D		;Check Status (info in [DH])
01:00091256 1204            	  2184: 	MOVE.B	D4,D1
01:00091258 02010080        	  2185: 	ANDI.B	#$80,D1
01:0009125C 671C            	  2186: 	BEQ	DoneInit		;Return if ready bit is zero
                            	  2187: 	
01:0009125E 2E3C0000FFFF    	  2188: 	MOVE.L	#$0FFFF,D7
01:00091264 1A3C0002        	  2189: DELAY2:	MOVE.B	#2,D5		;May need to adjust delay time to allow cold drive to
01:00091268 5305            	  2190: DELAY1:	SUBQ.B	#1,D5		;to speed
01:0009126A 66FC            	  2191: 	BNE	DELAY1
01:0009126C 5307            	  2192: 	SUBQ.B	#1,D7
01:0009126E 66F4            	  2193: 	BNE	DELAY2
                            	  2194: 
01:00091270 5306            	  2195: 	SUBQ.B	#1,D6
01:00091272 66DA            	  2196: 	BNE	WaitInit
01:00091274 6100FED6        	  2197: 	BSR	SHOWerrors		;Ret with NZ flag set if error (probably no drive)
01:00091278 4E75            	  2198: 	RTS
                            	  2199: DoneInit:
01:0009127A B341            	  2200: 	EOR	D1,D1
01:0009127C 4E75            	  2201: 	RTS
                            	  2202: 	
                            	  2203: DELAY_32: 
01:0009127E 123C0028        	  2204: 	MOVE.B	#40,D1		;DELAY ~32 MS (DOES NOT SEEM TO BE CRITICAL)
01:00091282 143C0000        	  2205: DELAY3:	MOVE.B	#0,D2
01:00091286 5302            	  2206: M0:	SUBQ.B	#1,D2
01:00091288 66FC            	  2207: 	BNE	M0
01:0009128A 5301            	  2208: 	SUBQ.B	#1,D1
01:0009128C 66F4            	  2209: 	BNE     DELAY3 
01:0009128E 4E75            	  2210: 	RTS
                            	  2211: 				;Read a sector, specified by the 4 bytes in LBA
                            	  2212: 				;Z on success, NZ BSR error routine if problem
                            	  2213: 				;Tell which sector we want to read from.
                            	  2214: READSECTOR:				;Note: Translate first in case of an error otherewise we 
01:00091290 610000F8        	  2215: 	BSR	WR_LBA		;will get stuck on bad sector 
01:00091294 6100019A        	  2216: 	BSR	IDEwaitnotbusy		;make sure drive is ready
01:00091298 6C04            	  2217: 	BGE	L_18	
01:0009129A 6000FEB0        	  2218: 	BRA	SHOWerrors		;Returned with NZ set if error
                            	  2219: 
01:0009129E 183C0001        	  2220: L_18:   MOVE.B	#$1,D4		;For CPM, one sector at a time
01:000912A2 1A3C000A        	  2221: 	MOVE.B	#REGseccnt,D5
01:000912A6 6100021E        	  2222: 	BSR	IDEwr8D		;Write to 8255 A Register
01:000912AA 61000184        	  2223: 	BSR	IDEwaitnotbusy		;make sure drive is ready
01:000912AE 6C04            	  2224: 	BGE	L_19	
01:000912B0 6000FE9A        	  2225: 	BRA	SHOWerrors		;Returned with NZ set if error
                            	  2226: 
01:000912B4 183C0020        	  2227: L_19:   MOVE.B	#COMMANDread,D4
01:000912B8 1A3C000F        	  2228: 	MOVE.B	#REGcommand,D5
01:000912BC 61000208        	  2229: 	BSR	IDEwr8D		;Send sec read command to drive.
01:000912C0 61000194        	  2230: 	BSR	IDEwaitdrq		;wait until it's got the data
01:000912C4 6C04            	  2231: 	BGE	L_20	
01:000912C6 6000FE84        	  2232: 	JMP	SHOWerrors
                            	  2233: 
01:000912CA 247A7234        	  2234: L_20:   MOVE.L	RAM_DMA,A2		;Get Current DMA Address to A2
01:000912CE 1C3C0000        	  2235: 	MOVE.B	#0,D6		;Read 512 bytes to D6
                            	  2236: 
                            	  2237: MoreRD16:
01:000912D2 13FC000800FF0032	  2238: 	MOVE.B	#REGdata,IDEportC		;REG regsiter address
01:000912DA 0039004000FF0032	  2239: 	OR.B 	#IDErdline,IDEportC		;08H+40H, Pulse RD line
                            	  2240: 	
01:000912E2 14F900FF0030    	  2241: 	MOVE.B	IDEportA,(A2)+		;Read the lower byte first 
01:000912E8 14F900FF0031    	  2242: 	MOVE.B	IDEportB,(A2)+		;Then the upper byte first 
                            	  2243: 	
01:000912EE 13FC000800FF0032	  2244: 	MOVE.B	#REGdata,IDEportC		;Deassert RD line
01:000912F6 5306            	  2245: 	SUBQ.B	#$1,D6
01:000912F8 66D8            	  2246: 	BNE	MoreRD16
                            	  2247: 	
01:000912FA 1A3C000F        	  2248: 	MOVE.B	#REGstatus,D5
01:000912FE 610001A2        	  2249: 	BSR	IDErd8D
01:00091302 1204            	  2250: 	MOVE.B	D4,D1
01:00091304 02010001        	  2251: 	ANDI.B	#$1,D1
01:00091308 6704            	  2252: 	BEQ	L_21	
01:0009130A 6100FE40        	  2253: 	BSR	SHOWerrors		;If error display status
01:0009130E 4E75            	  2254: L_21:	RTS
                            	  2255: 
                            	  2256: 
                            	  2257: 				;Write a sector, specified by the 3 bytes in LBA (_ IX+0)",
                            	  2258: 				;Z on success, NZ to error routine if problem
                            	  2259: 				;Tell which sector we want to read from.
                            	  2260: WRITESECTOR:			;Note: Translate first in case of an error otherewise we 
01:00091310 6178            	  2261: 	BSR	WR_LBA		;will get stuck on bad sector 
01:00091312 6100011C        	  2262: 	BSR	IDEwaitnotbusy		;make sure drive is ready
01:00091316 6C04            	  2263: 	BGE	L_22	
01:00091318 6000FE32        	  2264: 	JMP	SHOWerrors
                            	  2265: 	
01:0009131C 183C0030        	  2266: L_22:	MOVE.B	#COMMANDwrite,D4
01:00091320 1A3C000F        	  2267: 	MOVE.B	#REGcommand,D5
01:00091324 610001A0        	  2268: 	BSR	IDEwr8D		;tell drive to write a sector
01:00091328 6100012C        	  2269: 	BSR	IDEwaitdrq		;wait unit it wants the data
01:0009132C 6C04            	  2270: 	BGE	L_23	
01:0009132E 6000FE1C        	  2271: 	JMP	SHOWerrors
                            	  2272: 	
01:00091332 223A71CC        	  2273: L_23:	MOVE.L	RAM_DMA,D1
01:00091336 2441            	  2274: 	MOVE.L	D1,A2		;Get Current DMA Address
01:00091338 1C3C0000        	  2275: 	MOVE.B	#0,D6		;256X2 bytes
                            	  2276: 	
01:0009133C 13FC008000FF0033	  2277: 	MOVE.B	#WRITEcfg8255,IDECtrlPort
                            	  2278: 	
                            	  2279: WRSEC1_IDE:
01:00091344 13DA00FF0030    	  2280: 	MOVE.B	(A2)+,IDEportA
01:0009134A 13DA00FF0030    	  2281: 	MOVE.B	(A2)+,IDEportA
                            	  2282: 
01:00091350 13FC000800FF0032	  2283: 	MOVE.B	#REGdata,IDEportC
01:00091358 0039002000FF0032	  2284: 	OR.B	#IDEwrline,IDEportC		;Send WR pulse
01:00091360 13FC000800FF0032	  2285: 	MOVE.B	#REGdata,IDEportC
01:00091368 5306            	  2286: 	SUBQ.B	#$1,D6
01:0009136A 66D8            	  2287: 	BNE	WRSEC1_IDE
                            	  2288: 	
01:0009136C 13FC009200FF0033	  2289: 	MOVE.B	#READcfg8255,IDECtrlPort  ;Set 8255 back to read mode
                            	  2290: 	
01:00091374 1A3C000F        	  2291: 	MOVE.B	#REGstatus,D5
01:00091378 61000128        	  2292: 	BSR	IDErd8D
01:0009137C 1204            	  2293: 	MOVE.B	D4,D1
01:0009137E 02010001        	  2294: 	ANDI.B	#$1,D1
01:00091382 678A            	  2295: 	BEQ	L_21	
01:00091384 6100FDC6        	  2296: 	BSR	SHOWerrors		;If error display status
01:00091388 4E75            	  2297: L_24:	RTS
                            	  2298: 
                            	  2299: 				
                            	  2300: 				;Write the logical block address to the drive's registers
                            	  2301: 				;Note we do not need to set the upper nibble of the LBA
                            	  2302: 				;It will always be 0 for these small CPM drives (so no High Cylinder
                            	  2303: WR_LBA:				;numbers etc).
01:0009138A 183A7181        	  2304: 	MOVE.B	RAM_SEC,D4		;LBA mode, Low sectors go directly 
01:0009138E 5204            	  2305: 	ADDQ.B	#$1,D4		;Sectors are numbered 1 -- MAXSEC (even in LBA mode)
01:00091390 13C40009850A    	  2306: 	MOVE.B	D4,RAM_DRIVE_SEC		;For Diagnostic Diaplay Only
01:00091396 1A3C000B        	  2307: 	MOVE.B	#REGsector,D5		;Send info to drive
01:0009139A 6100012A        	  2308: 	BSR	IDEwr8D		;Write to 8255 A Register
                            	  2309: 				;Note: For drive we will have 0 - MAXSEC sectors only
                            	  2310: 					
01:0009139E 183A716E        	  2311: 	MOVE.B	RAM_TRK,D4
01:000913A2 13C400098508    	  2312: 	MOVE.B	D4,RAM_DRIVE_TRK		;Send Low TRK#			
01:000913A8 1A3C000C        	  2313: 	MOVE.B	#REGcylinderLSB,D5
01:000913AC 61000118        	  2314: 	BSR	IDEwr8D		;Write to 8255 A Register
                            	  2315: 	
01:000913B0 183A715D        	  2316: 	MOVE.B	RAM_TRK+1,D4
01:000913B4 13C400098509    	  2317: 	MOVE.B	D4,RAM_DRIVE_TRK+1
01:000913BA 1A3C000D        	  2318: 	MOVE.B	#REGcylinderMSB,D5		;Send High TRK#
01:000913BE 61000106        	  2319: 	BSR	IDEwr8D		;Send High TRK# (in DH) to IDE Drive
01:000913C2 61000136        	  2320: 	BSR	IDEwr8D_X		;Special write to 8255 B Register (Not A) to update LED HEX Display 
                            	  2321: 				;High 8 bits ignored by IDE drive
                            	  2322: 	
01:000913C6 183C0001        	  2323: 	MOVE.B	#$1,D4		;For CPM, one sector at a time
01:000913CA 1A3C000A        	  2324: 	MOVE.B	#REGseccnt,D5
01:000913CE 610000F6        	  2325: 	BSR	IDEwr8D		;Write to 8255 A Register
01:000913D2 4E75            	  2326: 	RTS
                            	  2327:  	
                            	  2328: 				;Special version for MS-DOS system BIOS (see IBM BIOS Section)
                            	  2329: 				;This will display Head, Cylinder and Sector on the LED HEX display
                            	  2330: DOS_WR_LBA:				;instead of LBA sector numbers.
01:000913D4 183A713A        	  2331: 	MOVE.B	CURRENT_HEAD,D4		;OR in head info to lower 4 bits
01:000913D8 0204000F        	  2332: 	ANDI.B	#$0F,D4		;Just in case
01:000913DC 883C00A0        	  2333: 	OR.B	#%10100000,D4		;Set to >>>>> NON-LBA mode <<<<<
01:000913E0 1A3C000E        	  2334: 	MOVE.B	#REGshd,D5		;Send "Head #" (in DH) to IDE drive
01:000913E4 610000E0        	  2335: 	BSR	IDEwr8D				
                            	  2336: 
01:000913E8 183A7127        	  2337: 	MOVE.B	CURRENT_TRACK_HIGH,D4	;Send High TRK#
01:000913EC 1A3C000D        	  2338: 	MOVE.B	#REGcylinderMSB,D5
01:000913F0 610000D4        	  2339: 	BSR	IDEwr8D		;Send High TRK# (in DH) to IDE Drive
                            	  2340: 
01:000913F4 183A711A        	  2341: 	MOVE.B	CURRENT_HEAD,D4		;Get head info to lower 8 bits of the special
01:000913F8 0204000F        	  2342: 	ANDI.B	#$0F,D4		;top two LED HEX displays.
01:000913FC E94C            	  2343: 	LSL	#4,D4 		;These 8 (high) data lines are ignored by the IDE drive
01:000913FE 883A7111        	  2344: 	OR.B	CURRENT_TRACK_HIGH,D4	    ;Will display  the Head in top nibble and the two bits of the HIGH bits 
01:00091402 1A3C000D        	  2345: 	MOVE.B	#REGcylinderMSB,D5		;of the high cylinder in the low nibble.
01:00091406 610000F2        	  2346: 	BSR	IDEwr8D_X		;Special output to 8255 B Register (Not A) to update LED HEX Display ONLY
                            	  2347: 						
01:0009140A 183A7106        	  2348: 	MOVE.B	CURRENT_TRACK,D4		;Get low Track # 
01:0009140E 1A3C000C        	  2349: 	MOVE.B	#REGcylinderLSB,D5		;Send Low TRK# (in DH)
01:00091412 610000B2        	  2350: 	BSR	IDEwr8D		;Special write to 8255 B Register (Not A) 
                            	  2351: 	
01:00091416 183A70FB        	  2352: 	MOVE.B	CURRENT_SECTOR,D4		;Bits 0-5 only  (currently 1-17)
01:0009141A 1A3C000B        	  2353: 	MOVE.B	#REGsector,D5		;Send "Sector#" 
01:0009141E 610000A6        	  2354: 	BSR	IDEwr8D		;Write to 8255 A Register
                            	  2355: 
01:00091422 183A70F0        	  2356: 	MOVE.B	SECTORS_TO_DO,D4		;# of CONTIGOUS sectors to send
01:00091426 1A3C000A        	  2357: 	MOVE.B	#REGseccnt,D5
01:0009142A 6100009A        	  2358: 	BSR	IDEwr8D		;Write to 8255 A Register
01:0009142E 4E75            	  2359: 	RTS
                            	  2360: 
                            	  2361: 
                            	  2362: 
                            	  2363: IDEwaitnotbusy:			;Drive READY if 01000000
01:00091430 3C3CFFFF        	  2364: 	MOVE.W	#$0FFFF,D6
                            	  2365: MoreWait:
01:00091434 1A3C000F        	  2366: 	MOVE.B	#REGstatus,D5		;wait for RDY bit to be set
01:00091438 6168            	  2367: 	BSR	IDErd8D		;Note AH or CH are unchanged
01:0009143A 1204            	  2368: 	MOVE.B	D4,D1
01:0009143C 020100C0        	  2369: 	ANDI.B	#%11000000,D1
01:00091440 0A010040        	  2370: 	EOR.B	#%01000000,D1
01:00091444 670C            	  2371: 	BEQ	DONE_NOT_BUSY
01:00091446 5346            	  2372: 	SUBQ.W	#1,D6
01:00091448 66EA            	  2373: 	BNE	MoreWait
01:0009144A 103C00FF        	  2374: 	MOVE.B	#$FF,D0			
01:0009144E E308            	  2375: 	LSL.B	#1,D0		;Set carry to indicate an error
01:00091450 4E75            	  2376: 	RTS
                            	  2377: DONE_NOT_BUSY:
01:00091452 4201            	  2378: 	CLR.B	D1		;Clear carry it indicate no error
01:00091454 4E75            	  2379: 	RTS
                            	  2380: 			
                            	  2381: 				;Wait for the drive to be ready to transfer data.
                            	  2382: IDEwaitdrq:				;Returns the drive's status in Acc
01:00091456 3C3CFFFF        	  2383: 	MOVE.W	#$0FFFF,D6
                            	  2384: MoreDRQ:
01:0009145A 1A3C000F        	  2385: 	MOVE.B	#REGstatus,D5		;wait for DRQ bit to be set
01:0009145E 6142            	  2386: 	BSR	IDErd8D		;Note AH or CH are unchanged
01:00091460 1204            	  2387: 	MOVE.B	D4,D1
01:00091462 02010088        	  2388: 	ANDI.B	#%10001000,D1
01:00091466 B23C0008        	  2389: 	CMP.B	#%00001000,D1
01:0009146A 670C            	  2390: 	BEQ	DoneDRQ
01:0009146C 5346            	  2391: 	SUBQ.W	#1,D6
01:0009146E 66EA            	  2392: 	BNE	MoreDRQ
01:00091470 103C00FF        	  2393: 	MOVE.B	#$FF,D0			
01:00091474 E308            	  2394: 	LSL.B	#1,D0		;Set carry to indicate an error
01:00091476 4E75            	  2395: 	RTS
                            	  2396: DoneDRQ:
01:00091478 4201            	  2397: 	CLR.B	D1		;Clear carry it indicate no error
01:0009147A 4E75            	  2398: 	RTS
                            	  2399: 
                            	  2400: 
                            	  2401: CLEAR_ID_BUFFER:			;Clear the ID Buffer area
01:0009147C 323C2020        	  2402: 	MOVE.W	#$2020,D1		;Clear to spaces
01:00091480 45FA6C7E        	  2403: 	LEA	IDE_BUFFER,A2		
01:00091484 143C00FF        	  2404: 	MOVE.B	#255,D2		;512 bytes total
01:00091488 34C1            	  2405: CLEAR2:	MOVE.W	D1,(A2)+
01:0009148A 5302            	  2406: 	SUBQ.B	#1,D2
01:0009148C 66FA            	  2407: 	BNE	CLEAR2
                            	  2408: 
01:0009148E 323C0000        	  2409: 	MOVE.W	#$0000,D1		;Clear to 0
01:00091492 45FA6C6C        	  2410: 	LEA	IDE_BUFFER,A2		
01:00091496 143C0007        	  2411: 	MOVE.B	#7,D2		;14 bytes total
01:0009149A 34C1            	  2412: CLEAR3:	MOVE.W	D1,(A2)+
01:0009149C 5302            	  2413: 	SUBQ.B	#1,D2
01:0009149E 66FA            	  2414: 	BNE	CLEAR3
01:000914A0 4E75            	  2415: 	RTS
