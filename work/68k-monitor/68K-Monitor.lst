01:00090E44 6100FAA0        	  1756: 	BSR	SELECT_DRIVE
                            	  1757: 
01:00090E48 61000540        	  1758: 	BSR	WR_LBA	;Update LBA on "A:" drive
                            	  1759: 
01:00090E4C 49FA72B2        	  1760: 	LEA	IDE_BUFFER,A4
01:00090E50 23CC00098500    	  1761: 	MOVE.L	A4,(RAM_DMA)
                            	  1762: 	
01:00090E56 61000438        	  1763: 	BSR	READSECTOR	;Get sector data from A: drive to buffer
                            	  1764: 
01:00090E5A 123C0001        	  1765: 	MOVE.B	#1,D1	;Login drive B:
01:00090E5E 6100FA86        	  1766: 	BSR	SELECT_DRIVE
                            	  1767: 	
01:00090E62 61000526        	  1768: 	BSR	WR_LBA	;Update LBA on "B:" drive
                            	  1769: 
01:00090E66 49FA7498        	  1770: 	LEA	IDE_BUFFER2,A4
01:00090E6A 23CC00098500    	  1771: 	MOVE.L	A4,(RAM_DMA)	;DMA initially to IDE_BUFFER2
                            	  1772: 	
01:00090E70 6100041E        	  1773: 	BSR	READSECTOR
                            	  1774: 
01:00090E74 45FA748A        	  1775: 	LEA	IDE_BUFFER2,A2
01:00090E78 47FA7286        	  1776: 	LEA	IDE_BUFFER,A3
01:00090E7C 323C0200        	  1777: 	MOVE.W	#512,D1	;Length of sector in words
                            	  1778: 
                            	  1779: NEXT_CMP:
01:00090E80 B70A            	  1780: 	CMP.B	(A2)+,(A3)+	;Are they the same
01:00090E82 6606            	  1781: 	BNE	VER_ERROR
01:00090E84 5341            	  1782: 	SUBQ.W	#1,D1
01:00090E86 66F8            	  1783: 	BNE	NEXT_CMP	;CX will contain count of words done so far, (0 if done OK)
01:00090E88 604E            	  1784: 	BRA	IDE_VERIFY_OK
                            	  1785: 
                            	  1786: VER_ERROR:
01:00090E8A 45FA1BB3        	  1787: 	LEA	VERIFY_ERR,A2	;Indicate an error
01:00090E8E 61000AB2        	  1788: 	BSR	PRINT_STRING
01:00090E92 61000186        	  1789: 	BSR	SHOW_TRACK_SEC	;Show current location of error
01:00090E96 45FA1C79        	  1790: 	LEA	DRIVE1_MSG,A2	;'  Drive A',CR,LF
01:00090E9A 61000AA6        	  1791: 	BSR	PRINT_STRING
                            	  1792: 
01:00090E9E 45FA7260        	  1793: 	LEA	IDE_BUFFER,A2
01:00090EA2 323C0200        	  1794: 	MOVE.W	#512,D1	;Length of sector in words
                            	  1795: VER_SOURCE:	
01:00090EA6 1C1A            	  1796: 	MOVE.B	(A2)+,D6	;Show source values
01:00090EA8 6100097C        	  1797: 	BSR	PUTBYTE_D6
01:00090EAC 5341            	  1798: 	SUBQ.W	#1,D1
01:00090EAE 66F6            	  1799: 	BNE	VER_SOURCE
01:00090EB0 61000A9E        	  1800: 	BSR	CRLF
01:00090EB4 61000164        	  1801: 	BSR	SHOW_TRACK_SEC	;Show current location of error
01:00090EB8 45FA1C66        	  1802: 	LEA	DRIVE2_MSG,A2	;'  Drive B',CR,LF
01:00090EBC 61000A84        	  1803: 	BSR	PRINT_STRING
                            	  1804: 
01:00090EC0 45FA743E        	  1805: 	LEA	IDE_BUFFER2,A2
01:00090EC4 323C0200        	  1806: 	MOVE.W	#512,D1	;Length of sector in words
                            	  1807: VER_DEST:	
01:00090EC8 1C1A            	  1808: 	MOVE.B	(A2)+,D6	;show destination values
01:00090ECA 6100095A        	  1809: 	BSR	PUTBYTE_D6
01:00090ECE 5341            	  1810: 	SUBQ.W	#1,D1
01:00090ED0 66F6            	  1811: 	BNE	VER_DEST
01:00090ED2 61000A7C        	  1812: 	BSR	CRLF
01:00090ED6 600C            	  1813: 	BRA	VERIFYT	;Do not ask for a continue message here. Just continue
                            	  1814: 			;If you want it change to VERIFYT1
                            	  1815: IDE_VERIFY_OK:
01:00090ED8 4A390009850D    	  1816: 	CMP.B	#0,(RAM_SEC)	;Get Current Sector
01:00090EDE 6604            	  1817: 	BNE	VERIFYT
                            	  1818: 	
01:00090EE0 61000162        	  1819: 	BSR	SHOW_TRACK
                            	  1820: 
                            	  1821: VERIFYT:
01:00090EE4 610009C2        	  1822: 	BSR	GETSTAT	;Any keyboard character will stop display
01:00090EE8 6718            	  1823: 	BEQ	V_NEXTSEC1
01:00090EEA 610009A8        	  1824: 	BSR	GETCHAR	;Flush character
                            	  1825: VERIFYT1:
01:00090EEE 45FA19A5        	  1826: 	LEA	CONTINUE_MSG,A2
01:00090EF2 61000A4E        	  1827: 	BSR	PRINT_STRING
01:00090EF6 6100099C        	  1828: 	BSR	GETCHAR
01:00090EFA B23C001B        	  1829: 	CMP.B	#ESC,D1
01:00090EFE 6602            	  1830: 	BNE	V_NEXTSEC1
01:00090F00 6012            	  1831: 	BRA	V_NEXTSEC3
                            	  1832: V_NEXTSEC1:
01:00090F02 610001D8        	  1833: 	BSR	GET_NEXT_SECT	;Update to next sector/track
01:00090F06 6604            	  1834: 	BNE	V_NEXTSEC2
01:00090F08 6000FF36        	  1835: 	BRA	NextVCopy
                            	  1836: V_NEXTSEC2:	
01:00090F0C 45FA1B43        	  1837: 	LEA	VerifyDone,A2	;Tell us we are all done.
01:00090F10 61000A30        	  1838: 	BSR	PRINT_STRING
                            	  1839: V_NEXTSEC3:
01:00090F14 123C0000        	  1840: 	MOVE.B	#0,D1	;Login drive A:
01:00090F18 6100F9CC        	  1841: 	BSR	SELECT_DRIVE
01:00090F1C 13C10009850F    	  1842: 	MOVE.B	D1,(CURRENT_IDE_DRIVE)
01:00090F22 61000A2C        	  1843: 	BSR	CRLF	
01:00090F26 6000F928        	  1844: 	BRA	IDE_LOOP	;Back to IDE Menu
                            	  1845: 
