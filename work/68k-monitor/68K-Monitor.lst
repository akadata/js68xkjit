01:000900B0 97CB            	   335: MEM_MAP:	MOVE.L	#0,A3	;A Command.   Do Memory Map. Pointer to RAM area A3=0
01:000900B2 6100189C        	   336: NEWLINE:	BSR	CRLF
01:000900B6 2E0B            	   337: 	MOVE.L	A3,D7
01:000900B8 6100172C        	   338: 	BSR	PUTLONG_D7	;Print long value of D7
01:000900BC 7640            	   339: 	MOVE.L	#64,D3	;64 characters across per line
01:000900BE 7AFF            	   340: 	MOVE.L	#$FFFFFFFF,D5
                            	   341: 	
01:000900C0 123C0020        	   342: 	MOVE.B	#BLANK,D1
